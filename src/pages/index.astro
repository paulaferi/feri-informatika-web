---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { readFileSync } from "fs";
import { resolve } from "path";

const base = import.meta.env.BASE_URL;

let highlightedNewsIds: string[]         = [];
let highlightedAchievementsIds: string[] = [];
let highlightedProjectsIds: string[]     = [];

try {
  const configPath = resolve("src/content/config/highlighted.json");
  const raw = readFileSync(configPath, "utf-8");
  const config = JSON.parse(raw);
  highlightedNewsIds         = config.news         ?? [];
  highlightedAchievementsIds = config.achievements ?? [];
  highlightedProjectsIds     = config.projects     ?? [];
} catch {}

function normalizeId(str: string): string {
  return str
    .toLowerCase()
    .replace(/[\u{1F000}-\u{1FFFF}]/gu, '')
    .replace(/[\u{2600}-\u{27BF}]/gu, '')
    .replace(/[»«""''–—]/g, '')
    .replace(/[čć]/g, 'c')
    .replace(/[šś]/g, 's')
    .replace(/[žź]/g, 'z')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/[^\w-]/g, '')
    .trim();
}

function findById<T extends { id: string; slug?: string }>(
  collection: T[], ids: string[]
): T[] {
  return ids
    .map(id => {
      const norm = normalizeId(id);
      return collection.find(n =>
        n.id === id || n.slug === id ||
        normalizeId(n.id) === norm ||
        normalizeId(n.slug ?? '') === norm
      );
    })
    .filter(Boolean) as T[];
}

const allNews         = await getCollection("news");
const allAchievements = await getCollection("achievements");
const allProjects     = await getCollection("projects");

const highlightedNews         = findById(allNews, highlightedNewsIds).slice(0, 3);
const highlightedAchievements = findById(allAchievements, highlightedAchievementsIds).slice(0, 3);
const highlightedProjects     = findById(allProjects, highlightedProjectsIds).slice(0, 3);
---
<Base title="Inštitut za Informatiko">


  {highlightedNews.length > 0 && (
    <div class="card" style="margin-top:1.25rem;">
      <div class="section-heading"><h3>Highlighted News</h3></div>
      <div class="card-grid">
        {highlightedNews.map(n => (
          <a href={`${base}/news/${n.id}`} class="grid-card">
            <div class="grid-card-image">
              {(() => {
                const cover = n.data.coverImage ?? (n.data.images && n.data.images[0]);
                return cover
                  ? <Image src={cover} alt={n.data.title} width={400} height={168} />
                  : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
              })()}
            </div>
            <div class="grid-card-accent"></div>
            <div class="grid-card-body">
              <time class="grid-card-date">
                {new Date(n.data.date).toLocaleDateString("en-GB", {
                  day: "numeric", month: "long", year: "numeric"
                })}
              </time>
              <h3 class="grid-card-title">{n.data.title}</h3>
              <p class="grid-card-summary">{n.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {highlightedAchievements.length > 0 && (
    <div class="card" style="margin-top:1.25rem;">
      <div class="section-heading"><h3>Highlighted Achievements</h3></div>
      <div class="card-grid">
        {highlightedAchievements.map(a => (
          <a href={`${base}/achievements/${a.id}`} class="grid-card">
            <div class="grid-card-image">
              {(() => {
                const cover = a.data.coverImage ?? (a.data.images && a.data.images[0]);
                return cover
                  ? <Image src={cover} alt={a.data.title} width={400} height={168} />
                  : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
              })()}
            </div>
            <div class="grid-card-accent"></div>
            <div class="grid-card-body">
              <time class="grid-card-date">
                {new Date(a.data.date).toLocaleDateString("en-GB", {
                  day: "numeric", month: "long", year: "numeric"
                })}
              </time>
              <h3 class="grid-card-title">{a.data.title}</h3>
              {a.data.subtitle && (
                <p style="font-size:0.78rem; color:var(--muted); font-style:italic; margin:0 0 0.4rem;">
                  {a.data.subtitle}
                </p>
              )}
              <p class="grid-card-summary">{a.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {highlightedProjects.length > 0 && (
    <div class="card" style="margin-top:1.25rem;">
      <div class="section-heading"><h3>Highlighted Projects</h3></div>
      <div class="card-grid">
        {highlightedProjects.map(p => (
          <a href={`${base}/research/projects/${p.id}`} class="project-card">
            <div class={`project-card-status ${p.data.status}`}>
              {p.data.status === "active" ? "Active" : "Completed"}
            </div>
            <h3 class="project-card-title">{p.data.title}</h3>
            <p class="project-card-desc">{p.data.description}</p>
            <p class="project-card-year">
              {p.data.startYear}
              {p.data.endYear ? `–${p.data.endYear}` : p.data.status === "active" ? "–present" : ""}
            </p>
          </a>
        ))}
      </div>
    </div>
  )}

</Base>