---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { readFileSync } from "fs";
import { resolve } from "path";

const base = import.meta.env.BASE_URL;

const slidesRaw = (await getCollection("heroSlides"))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

let highlightedNewsIds: string[]         = [];
let highlightedAchievementsIds: string[] = [];
let highlightedProjectsIds: string[]     = [];

try {
  const configPath = resolve("src/content/config/highlighted.json");
  const raw = readFileSync(configPath, "utf-8");
  const config = JSON.parse(raw);
  highlightedNewsIds         = config.news         ?? [];
  highlightedAchievementsIds = config.achievements ?? [];
  highlightedProjectsIds     = config.projects     ?? [];
} catch {}

function normalizeId(str: string): string {
  return str
    .toLowerCase()
    .replace(/[\u{1F000}-\u{1FFFF}]/gu, '')
    .replace(/[\u{2600}-\u{27BF}]/gu, '')
    .replace(/[»«""''–—]/g, '')
    .replace(/[čć]/g, 'c')
    .replace(/[šś]/g, 's')
    .replace(/[žź]/g, 'z')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/[^\w-]/g, '')
    .trim();
}

function findById<T extends { id: string; slug?: string }>(
  collection: T[], ids: string[]
): T[] {
  return ids
    .map(id => {
      const norm = normalizeId(id);
      return collection.find(n =>
        n.id === id || n.slug === id ||
        normalizeId(n.id) === norm ||
        normalizeId(n.slug ?? '') === norm
      );
    })
    .filter(Boolean) as T[];
}

const allNews         = await getCollection("news");
const allAchievements = await getCollection("achievements");
const allProjects     = await getCollection("projects");

const highlightedNews         = findById(allNews, highlightedNewsIds).slice(0, 3);
const highlightedAchievements = findById(allAchievements, highlightedAchievementsIds).slice(0, 3);
const highlightedProjects     = findById(allProjects, highlightedProjectsIds).slice(0, 3);

const slides = slidesRaw.map(s => ({
  title: s.data.title,
  subtitle: s.data.subtitle,
  image: s.data.image?.src ?? "",  
}));
---
<Base title="Inštitut za Informatiko" fullWidth>

  <section class="hero-carousel">
    <button class="hero-carousel-arrow hero-carousel-prev" aria-label="Previous slide">‹</button>
    <button class="hero-carousel-arrow hero-carousel-next" aria-label="Next slide">›</button>

    <div class="hero-carousel-track" id="hero-track">
      {slides.map(s => (
        <div class="hero-slide">
          <div class="hero-slide-text">
            <h1 class="hero-slide-title">{s.title}</h1>
            <p class="hero-slide-subtitle">{s.subtitle}</p>
          </div>
          <div class="hero-slide-image" style={`background-image: url(${s.image});`}></div>
        </div>
      ))}
    </div>

    <div class="hero-carousel-dots">
      {slides.map((_, i) => (
        <span class={`hero-carousel-dot${i === 0 ? " active" : ""}`} data-index={i}></span>
      ))}
    </div>
  </section>

  <div class="home-section">

    <h1 class="page-title">Inštitut za Informatiko</h1>
    <div class="page-title-rule"></div>

  {highlightedNews.length > 0 && (
    <div class="card" style="margin-top:1.25rem;">
      <div class="section-heading"><h3>Izpostavljene novice</h3></div>
      <div class="card-grid">
        {highlightedNews.map(n => (
          <a href={`${base}/news/${n.id}`} class="grid-card">
            <div class="grid-card-image">
              {(() => {
                const cover = n.data.coverImage ?? (n.data.images && n.data.images[0]);
                return cover
                  ? <Image src={cover} alt={n.data.title}  />
                  : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
              })()}
            </div>
            <div class="grid-card-accent"></div>
            <div class="grid-card-body">
              <time class="grid-card-date">
                {new Date(n.data.date).toLocaleDateString("sl-SI", {
                  day: "numeric", month: "long", year: "numeric"
                })}
              </time>
              <h3 class="grid-card-title">{n.data.title}</h3>
              <p class="grid-card-summary">{n.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {highlightedAchievements.length > 0 && (
    <div class="card" style="margin-top:1.25rem;">
      <div class="section-heading"><h3>Izpostavljene dosežke</h3></div>
      <div class="card-grid">
        {highlightedAchievements.map(a => (
          <a href={`${base}/achievements/${a.id}`} class="grid-card">
            <div class="grid-card-image">
              {(() => {
                const cover = a.data.coverImage ?? (a.data.images && a.data.images[0]);
                return cover
                  ? <Image src={cover} alt={a.data.title}  />
                  : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
              })()}
            </div>
            <div class="grid-card-accent"></div>
            <div class="grid-card-body">
              <time class="grid-card-date">
                {a.data.date && new Date(a.data.date).toLocaleDateString("sl-SI", {
                  day: "numeric", month: "long", year: "numeric"
                })}
              </time>
              <h3 class="grid-card-title">{a.data.title}</h3>
              {a.data.subtitle && (
                <p style="font-size:0.78rem; color:var(--muted); font-style:italic; margin:0 0 0.4rem;">
                  {a.data.subtitle}
                </p>
              )}
              <p class="grid-card-summary">{a.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {highlightedProjects.length > 0 && (
    <div class="card" style="margin-top:1.25rem;">
      <div class="section-heading"><h3>Izpostavljeni projekti</h3></div>
      <div class="card-grid">
        {highlightedProjects.map(p => (
          <a href={`${base}/research/projects/${p.id}`} class="project-card">
            <div class={`project-card-status ${p.data.status}`}>
              {p.data.status === "active" ? "Aktivno" : "Zaključeno"}
            </div>
            <h3 class="project-card-title">{p.data.title}</h3>
            <p class="project-card-desc">{p.data.description}</p>
            <p class="project-card-year">
              {p.data.startYear}
              {p.data.endYear ? `–${p.data.endYear}` : p.data.status === "active" ? "-sedanjost" : ""}
            </p>
          </a>
        ))}
      </div>
    </div>
  )}

  </div>

</Base>

<script>
  const track = document.getElementById("hero-track");
  const heroDots = document.querySelectorAll(".hero-carousel-dot");
  const prevHero = document.querySelector(".hero-carousel-prev");
  const nextHero = document.querySelector(".hero-carousel-next");
  const slideCount = heroDots.length;
  let currentSlide = 0;

  function showSlide(index: number) {
    if (!track || slideCount === 0) return;
    currentSlide = (index + slideCount) % slideCount;
    track.style.transform = `translateX(-${currentSlide * 100}%)`;
    heroDots.forEach((dot, i) => dot.classList.toggle("active", i === currentSlide));
  }

  if (track && prevHero && nextHero && slideCount > 0) {
    prevHero.addEventListener("click", () => showSlide(currentSlide - 1));
    nextHero.addEventListener("click", () => showSlide(currentSlide + 1));
    heroDots.forEach((dot, i) => dot.addEventListener("click", () => showSlide(i)));
    setInterval(() => showSlide(currentSlide + 1), 6000);
  }
</script>