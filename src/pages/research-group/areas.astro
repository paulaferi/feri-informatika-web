---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Research Areas",  href: `${base}/research-group/areas` },
  { label: "Link to SICRIS",  href: `${base}/research-group/sicris` },
];

const areas = [
  "Information Systems",
  "Software Engineering",
  "Embedded Systems",
  "Intelligent Systems",
  "Information and Communication Technologies",
];
---
<Base title="Research Areas" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Research Areas</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>The Institute of Informatics covers a wide range of research areas, including distributed systems, artificial intelligence, computer networks, software development and human-computer interaction.</p>
    </div>

    <div class="section-heading"><h3>Main Areas</h3></div>
    <ul class="dot-list">
      {areas.map(area => <li>{area}</li>)}
    </ul>
  </div>

  <SectionNews tag="scientific" label="Latest News" />

</Base>
