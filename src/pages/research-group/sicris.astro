---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Research Areas",  href: `${base}/research-group/areas` },
  { label: "Link to SICRIS",  href: `${base}/research-group/sicris` },
];
---
<Base title="Link to SICRIS" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Link to SICRIS</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>Full information about the research group, including members and bibliographic records, is available in the national SICRIS system.</p>
    </div>

    <div class="section-heading"><h3>External Resource</h3></div>
    <p style="margin-bottom:0;">
      <a href="https://www.sicris.si/" target="_blank"
         style="font-weight:700; font-size:1rem;">View SICRIS →</a>
    </p>
  </div>

  <SectionNews tag="scientific" label="Latest News" />

</Base>
