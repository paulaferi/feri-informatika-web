---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Raziskovalna področja", href: `${base}/research-group/areas` },
  { label: "Povezava do SICRIS",    href: `${base}/research-group/sicris` },
];
---
<Base title="Povezava do SICRIS" sidebarLinks={sidebarLinks}>

  <h2 style="font-family:'Titillium Web',sans-serif; font-size:1.4rem; font-weight:400;
             color:#222; margin-bottom:1.25rem;">
    Povezava do SICRIS
  </h2>

  <div class="card">
    <div style="display:flex; gap:0.75rem; align-items:stretch; margin-bottom:1.5rem;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px;"></div>
      <p style="margin:0; text-align:left;">
        Celotne informacije o raziskovalni skupini, vključno s člani in bibliografskimi
        zapisi, so na voljo v nacionalnem sistemu SICRIS.
      </p>
    </div>

    <div style="display:flex; gap:0.75rem; align-items:center;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px; min-height:24px;"></div>
      <a href="https://www.sicris.si/" target="_blank"
         style="font-size:1.05rem; color:#006A8E; text-decoration:none; font-weight:600;">
        Ogled na SICRIS →
      </a>
    </div>
  </div>

  <SectionNews tag="scientific" label="ZADNJE NOVICE" />

</Base>