---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const labs = await getCollection("laboratories");
  return labs.map(lab => ({ params: { id: lab.id }, props: { lab } }));
}

const { lab } = Astro.props;
const { Content } = await render(lab);
const base = import.meta.env.BASE_URL;

const allLabs = await getCollection("laboratories");
const allStaff = await getCollection("staff");
const members = allStaff.filter(s => (lab.data.members ?? []).includes(s.id));

const sidebarLinks = [
  {
    label: "Laboratoriji",
    href: `${base}/laboratories`,
    children: allLabs.map(l => ({
      label: l.data.name,
      href: `${base}/laboratories/${l.id}`,
    })),
  },
  { label: "Interesne skupine", href: `${base}/interest-groups` },
  { label: "Osebje",           href: `${base}/staff` },
];
---
<Base title={lab.data.name} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">
    {lab.data.name}
    {lab.data.acronym && (
      <span style="font-size:1rem; color:var(--muted); font-weight:400;">({lab.data.acronym})</span>
    )}
  </h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="intro"><p>{lab.data.description}</p></div>

    {lab.data.researchAreas && lab.data.researchAreas.length > 0 && (
      <div>
        <div class="section-heading"><h3>Raziskovalna področja</h3></div>
        <ul class="dot-list">
          {lab.data.researchAreas.map((a: string) => <li>{a}</li>)}
        </ul>
      </div>
    )}

    {members.length > 0 && (
      <div style="margin-top:1.5rem;">
        <div class="section-heading"><h3>Člani laboratorija</h3></div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(210px,1fr)); gap:0.75rem;">
          {members.map(m => (
            <a href={`${base}/staff/${m.id}`}
               style="display:flex; align-items:center; gap:0.7rem; text-decoration:none;
                      padding:0.6rem; border:1px solid var(--border); border-radius:4px;
                      transition:border-color .15s;">
              {m.data.photo
                ? <Image src={m.data.photo} alt={m.data.name} 
                         style="width:42px; height:42px; border-radius:50%; object-fit:cover; flex-shrink:0;" />
                : <div style="width:42px; height:42px; border-radius:50%; background:var(--um-blue-light);
                               display:flex; align-items:center; justify-content:center;
                               font-size:1rem; color:var(--um-blue); font-weight:700; flex-shrink:0;">
                    {m.data.name.charAt(0)}
                  </div>
              }
              <div style="min-width:0;">
                <div style="font-size:0.85rem; font-weight:700; color:var(--um-blue); line-height:1.3;">
                  {m.data.name}
                </div>
                <div style="font-size:0.73rem; color:var(--muted);">{m.data.role}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {lab.data.body && (
      <div style="margin-top:1.5rem;">
        <div class="section-heading"><h3>Opis</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {lab.data.externalUrl && (
      <div class="external-link">
        <a href={lab.data.externalUrl} target="_blank">Spletna stran laboratorija →</a>
      </div>
    )}

  </div>

  <SectionNews tag="scientific" label="Najnovejše novice" />

</Base>
