---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const labs = await getCollection("laboratories");
const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Laboratoriji",    href: `${base}/laboratories` },
  { label: "Interesne skupine", href: `${base}/interest-groups` },
  { label: "Osebje",           href: `${base}/staff` },
];
---
<Base title="Laboratoriji" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Laboratoriji</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>Inštitut za informatiko izvaja raziskave na področju informacijskih sistemov, rešitev in storitev, ki temeljijo na uporabi informacijskih in komunikacijskih tehnologij.</p>
    </div>

    <div class="section-heading"><h3>Laboratoriji Instituta</h3></div>

    <ul class="arrow-list">
      {labs.map(lab => (
        <li>
          <span class="arrow-icon">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <a href={`${base}/laboratories/${lab.id}`}>
            {lab.data.name}
            {lab.data.acronym && (
              <span style="font-size:0.82rem; color:var(--muted); font-weight:400; margin-left:5px;">
                ({lab.data.acronym})
              </span>
            )}
          </a>
        </li>
      ))}
      {labs.length === 0 && <li class="empty-state">Ni na voljo še nobenega laboratorija.</li>}
    </ul>
  </div>

  <SectionNews tag="interest-groups" label="Najnovejše novice" />

</Base>
