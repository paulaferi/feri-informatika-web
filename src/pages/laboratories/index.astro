---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const labs = await getCollection("laboratories");
---
<Base title="Laboratories">
  <h1>Laboratoriji</h1>
  <p style="color:#555; margin-bottom:1.5rem;">
    Inštitut za informatiko vodi raziskave na področju informacijskih sistemov,
    rešitev in storitev, ki temeljijo na uporabi informacijskih in komunikacijskih tehnologij.
  </p>

  <h2 style="font-size:1.05rem; margin-bottom:0.75rem;">
    Laboratoriji Inštituta za informatiko
  </h2>

  <ul style="padding-left:1.4rem; line-height:2.2;">
    {labs.map(lab => (
      <li>
        <a href={`${base}/laboratories/${lab.id}`}
           style="color:#0066cc; text-decoration:none;">
          {lab.data.name}
          {lab.data.acronym && (
            <span style="font-size:0.82rem; color:#888; margin-left:4px;">
              ({lab.data.acronym})
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</Base>