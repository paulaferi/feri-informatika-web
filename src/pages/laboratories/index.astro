---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const labs = await getCollection("laboratories");
const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Laboratoriji",      href: `${base}/laboratories` },
  { label: "Interesne skupine", href: `${base}/interest-groups` },
  { label: "Osebje",            href: `${base}/staff` },
];
---
<Base title="Laboratoriji" sidebarLinks={sidebarLinks}>

  <h2 style="font-family:'Titillium Web',sans-serif; font-size:1.4rem; font-weight:400;
             color:#222; margin-bottom:1.25rem;">Laboratoriji</h2>

  <div class="card">
    <p style="margin-bottom:1.25rem; text-align:left;">
      Inštitut za informatiko izvaja raziskave na področju informacijskih sistemov,
      rešitev in storitev, ki temeljijo na uporabi informacijskih in komunikacijskih tehnologij.
    </p>
    <p style="font-weight:600; color:#222; margin-bottom:0.75rem; text-align:left;">
      Laboratoriji Inštituta za informatiko:
    </p>
    <ul style="list-style:none; padding:0;">
      {labs.map(lab => (
        <li style="display:flex; align-items:center; gap:0.75rem; padding:0.4rem 0;
                   border-bottom:1px solid #f5f5f5;">
          <span style="display:inline-flex; align-items:center; justify-content:center;
                       width:28px; height:28px; background:#ffc70f; flex-shrink:0;">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="#222" stroke-width="1.8"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <a href={`${base}/laboratories/${lab.id}`}
             style="color:#006A8E; text-decoration:none; font-size:1.05rem;">
            {lab.data.name}
            {lab.data.acronym && (
              <span style="font-size:0.85rem; color:#888; margin-left:4px;">
                ({lab.data.acronym})
              </span>
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <SectionNews tag="interest-groups" label="ZADNJE NOVICE" />
</Base>