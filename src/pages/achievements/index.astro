---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const all = (await getCollection("achievements"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL;
const tags = ["student", "conference", "scientific", "professional",
              "project", "awards", "interest-groups"];
---
<Base title="Achievements & Activities">
  <h1>Dosežki in dejavnosti</h1>

  <div id="tag-filters" style="margin-bottom:1.5rem; display:flex; flex-wrap:wrap; gap:8px; align-items:center;">
    <span style="font-size:0.85rem; color:#888; margin-right:4px;">Filter:</span>
    <button data-tag="" class="tag-btn active">All</button>
    {tags.map(t => <button data-tag={t} class="tag-btn">{t}</button>)}
  </div>

  <p id="empty-msg" style="color:#888; display:none;">Za to oznako ni dosežkov.</p>

  <div id="achievements-grid" class="achievements-grid">
    {all.map(a => (
      <div class="achievement-item"
           data-tags={Array.isArray(a.data.tags) ? a.data.tags.join(",") : a.data.tags}>
        <a href={`${base}/achievements/${a.id}`} class="achievement-card-link">
          <article class="achievement-card">

            <div class="achievement-card-image">
              {a.data.coverImage
                ? <Image src={a.data.coverImage} alt={a.data.title}
                         width={400} height={200}
                         style="width:100%; height:100%; object-fit:cover;" />
                : <div class="achievement-card-placeholder">II · FERI</div>
              }
            </div>

            <div class="achievement-card-body">
              <time class="achievement-date">
                {new Date(a.data.date).toLocaleDateString("en-GB", {
                  day: "numeric", month: "long", year: "numeric"
                })}
              </time>
              <h2 class="achievement-title">{a.data.title}</h2>
              {a.data.subtitle && (
                <p class="achievement-subtitle">{a.data.subtitle}</p>
              )}

              <div style="margin-top:0.75rem; display:flex; flex-wrap:wrap; gap:4px;">
                {(Array.isArray(a.data.tags) ? a.data.tags : [a.data.tags]).map((t: string) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>

          </article>
        </a>
      </div>
    ))}
  </div>
</Base>

<style>
  .achievements-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .achievement-item { display: block; }
  .achievement-card-link { text-decoration: none; display: block; height: 100%; }
  .achievement-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .achievement-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  .achievement-card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: #f0f4ff;
    flex-shrink: 0;
  }
  .achievement-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a5276;
    font-weight: 600;
    font-size: 1.1rem;
    background: #e8f0fe;
  }
  .achievement-card-body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .achievement-date {
    font-size: 0.78rem;
    color: #999;
    margin-bottom: 0.3rem;
    display: block;
  }
  .achievement-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a2e;
    margin: 0 0 0.3rem;
    line-height: 1.4;
  }
  .achievement-subtitle {
    font-size: 0.88rem;
    color: #666;
    margin: 0 0 0.5rem;
    font-style: italic;
  }
  .tag-btn {
    padding: 4px 14px;
    border-radius: 20px;
    border: 1px solid #1a5276;
    background: transparent;
    color: #1a5276;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all .15s;
  }
  .tag-btn.active { background: #1a5276; color: #fff; }
  .tag-btn:hover { opacity: 0.8; }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const items   = document.querySelectorAll<HTMLElement>(".achievement-item");
  const empty   = document.getElementById("empty-msg")!;

  function filter(tag: string) {
    buttons.forEach(b => b.classList.toggle("active", b.dataset.tag === tag));
    let visible = 0;
    items.forEach(item => {
      const itemTags = item.dataset.tags?.split(",") ?? [];
      const show = tag === "" || itemTags.includes(tag);
      item.style.display = show ? "block" : "none";
      if (show) visible++;
    });
    empty.style.display = visible === 0 ? "block" : "none";
  }

  buttons.forEach(b => b.addEventListener("click", () => filter(b.dataset.tag ?? "")));
</script> 