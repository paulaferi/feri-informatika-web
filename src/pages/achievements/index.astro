---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const all = (await getCollection("achievements"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL;
const tags = ["student", "conference", "scientific", "professional",
              "project", "awards", "interest-groups"];
---
<Base title="Achievements and Activities">

  <h1 class="page-title">Achievements and Activities</h1>
  <div class="page-title-rule"></div>

  <div class="filter-bar">
    <span class="filter-label">Filter</span>
    <button data-tag="" class="tag-btn active">All</button>
    {tags.map(t => <button data-tag={t} class="tag-btn">{t}</button>)}
  </div>

  <p id="empty-msg" class="empty-state" style="display:none;">No achievements for this tag.</p>

  <div id="grid" class="card-grid">
    {all.map(a => (
      <a href={`${base}/achievements/${a.id}`} class="grid-card achievement-item"
         data-tags={Array.isArray(a.data.tags) ? a.data.tags.join(",") : String(a.data.tags)}>
        <div class="grid-card-image">
          {(() => {
            const cover = a.data.coverImage ?? (a.data.images && a.data.images[0]);
            return cover
              ? <Image src={cover} alt={a.data.title} width={600} height={400} />
              : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
          })()}
        </div>
        <div class="grid-card-accent"></div>
        <div class="grid-card-body">
          <time class="grid-card-date">
            {new Date(a.data.date).toLocaleDateString("en-GB", {
              day: "numeric", month: "long", year: "numeric"
            })}
          </time>
          <h3 class="grid-card-title">{a.data.title}</h3>
          {a.data.subtitle && (
            <p style="font-size:0.81rem; color:var(--muted); font-style:italic; margin:0 0 0.4rem;">
              {a.data.subtitle}
            </p>
          )}
          {a.data.summary && <p class="grid-card-summary">{a.data.summary}</p>}
          <div class="grid-card-tags">
            {(Array.isArray(a.data.tags) ? a.data.tags : [String(a.data.tags)]).map((t: string) => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>

  {all.length === 0 && (
    <div class="card"><p class="empty-state" style="margin:0;">No achievements listed yet.</p></div>
  )}

</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const items   = document.querySelectorAll<HTMLElement>(".achievement-item");
  const empty   = document.getElementById("empty-msg")!;

  function filter(tag: string) {
    buttons.forEach(b => b.classList.toggle("active", b.dataset.tag === tag));
    let visible = 0;
    items.forEach(item => {
      const itemTags = item.dataset.tags?.split(",").map(t => t.trim()) ?? [];
      const show = tag === "" || itemTags.includes(tag);
      item.style.display = show ? "flex" : "none";
      if (show) visible++;
    });
    empty.style.display = visible === 0 ? "block" : "none";
  }

  buttons.forEach(b => b.addEventListener("click", () => filter(b.dataset.tag ?? "")));
</script>
