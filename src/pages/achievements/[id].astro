---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const achievements = await getCollection("achievements");
  return achievements.map(a => ({ params: { id: a.id }, props: { achievement: a } }));
}

const { achievement } = Astro.props;
const { Content } = await render(achievement);
const base = import.meta.env.BASE_URL;

const galleryImages = achievement.data.images ?? [];
---
<Base title={achievement.data.title} wide>

  <h1 class="page-title">{achievement.data.title}</h1>
  <div class="page-title-rule"></div>
  {achievement.data.subtitle && (
    <p class="page-subtitle">{achievement.data.subtitle}</p>
  )}

  <div class="card" style="min-width:0; overflow:hidden;">

    <p class="meta" style="margin-bottom:0.75rem;">
      {achievement.data.date && new Date(achievement.data.date).toLocaleDateString("sl-SI", {
              day: "numeric", month: "long", year: "numeric"
      })}
    </p>

    <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:1.25rem;">
      {(Array.isArray(achievement.data.tags) ? achievement.data.tags : [String(achievement.data.tags)]).map((t: string) => (
        <span class="tag">{t}</span>
      ))}
    </div>

    {achievement.data.coverImage && (
      <div style="margin-bottom:1.5rem; display:flex; justify-content:center;
                  background:var(--um-blue-light); border-radius:4px; padding:1rem;">
        <Image src={achievement.data.coverImage} alt={achievement.data.title}
               style="max-width:100%; max-height:550px; width:auto; height:auto;
                      object-fit:contain; display:block;" />
      </div>
    )}

    {achievement.data.summary && (
      <div class="intro"><p>{achievement.data.summary}</p></div>
    )}

    <div class="prose"><Content /></div>

    {galleryImages.length > 0 && (
      <div style="margin-top:1.75rem;">
        <div class="section-heading"><h3>Galerija</h3></div>
        <div class="gallery-masonry">
          {galleryImages.map((img: ImageMetadata, i: number) => (
            <button class="gallery-thumb" data-index={i} type="button"
                    aria-label={`Open image ${i + 1}`}>
              <Image src={img} alt="" />
            </button>
          ))}
        </div>

        <div id="lightbox-data" style="display:none;">
          {galleryImages.map((img: ImageMetadata) => (
            <Image src={img} alt="" 
                   class="lightbox-source" style="display:none;" />
          ))}
        </div>

        <div id="lightbox" class="lightbox" hidden>
          <button class="lightbox-close" aria-label="Close">×</button>
          <button class="lightbox-prev" aria-label="Previous">‹</button>
          <img class="lightbox-img" alt="" />
          <button class="lightbox-next" aria-label="Next">›</button>
          <div class="lightbox-counter"></div>
        </div>
      </div>
    )}

    {achievement.data.videos && achievement.data.videos.length > 0 && (
      <div style="margin-top:1.75rem;">
        <div class="section-heading"><h3>Videos</h3></div>
        {achievement.data.videos.map((videoUrl: string) => (
          <div style="margin-bottom:1rem; border-radius:4px; overflow:hidden; background:var(--um-blue-light);">
            <video 
              width="100%" 
              height="auto" 
              controls 
              style="display:block; max-width:100%;">
              <source src={videoUrl} type="video/mp4" />
              Tvoj brskalnik ne podpira videoposnetkov v formatu HTML5.
            </video>
          </div>
        ))}
      </div>
    )}

  </div>

  <a href={`${base}/achievements`} class="back-link">← Nazaj na dosežke</a>

  <SectionNews tag="awards" label="Najnovejše novice" />

</Base>

<style>
  .gallery-masonry {
    columns: 3;
    column-gap: 0.75rem;
  }
  @media (max-width: 768px) {
    .gallery-masonry { columns: 2; }
  }
  @media (max-width: 480px) {
    .gallery-masonry { columns: 1; }
  }
  .gallery-thumb {
    display: block;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    background: var(--um-blue-light);
    cursor: pointer;
    padding: 0;
    transition: border-color .15s, transform .15s;
    margin-bottom: 0.75rem;
    break-inside: avoid;
  }
  .gallery-thumb img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }
  .gallery-thumb:hover { border-color: var(--um-blue); transform: scale(1.02); }

  /* Lightbox */
  .lightbox {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 1000;
    display: flex; align-items: center; justify-content: center;
    padding: 2rem;
  }
  .lightbox[hidden] { display: none; }
  .lightbox-img {
    max-width: 90vw; max-height: 85vh;
    object-fit: contain;
    user-select: none;
  }
  .lightbox-close, .lightbox-prev, .lightbox-next {
    position: absolute;
    background: rgba(255,255,255,0.1);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
    font-size: 2rem;
    cursor: pointer;
    width: 48px; height: 48px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s;
    font-family: sans-serif;
    line-height: 1;
  }
  .lightbox-close:hover, .lightbox-prev:hover, .lightbox-next:hover {
    background: rgba(255,199,15,0.4);
  }
  .lightbox-close { top: 1.5rem; right: 1.5rem; }
  .lightbox-prev { left: 1.5rem; top: 50%; transform: translateY(-50%); }
  .lightbox-next { right: 1.5rem; top: 50%; transform: translateY(-50%); }
  .lightbox-counter {
    position: absolute; bottom: 1.5rem; left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
    font-family: 'Titillium Web', sans-serif;
    letter-spacing: 0.1em;
  }
  @media (max-width: 560px) {
    .lightbox-prev { left: 0.5rem; }
    .lightbox-next { right: 0.5rem; }
  }
  .prose {
    overflow-wrap: break-word;
    word-break: break-word;
    max-width: 100%;
  }
  .prose * {
    max-width: 100%;
  }
</style>

<script>
  const lightbox  = document.getElementById("lightbox") as HTMLElement | null;
  const lbImg     = document.querySelector(".lightbox-img") as HTMLImageElement | null;
  const lbClose   = document.querySelector(".lightbox-close") as HTMLButtonElement | null;
  const lbPrev    = document.querySelector(".lightbox-prev") as HTMLButtonElement | null;
  const lbNext    = document.querySelector(".lightbox-next") as HTMLButtonElement | null;
  const lbCounter = document.querySelector(".lightbox-counter") as HTMLElement | null;
  const thumbs    = document.querySelectorAll<HTMLButtonElement>(".gallery-thumb");
  const sources   = document.querySelectorAll<HTMLImageElement>(".lightbox-source");

  if (lightbox && lbImg && lbClose && lbPrev && lbNext && lbCounter && thumbs.length) {
    let currentIndex = 0;

    function show(idx: number) {
      currentIndex = (idx + sources.length) % sources.length;
      lbImg!.src = sources[currentIndex].src;
      lbImg!.srcset = sources[currentIndex].srcset;
      lbCounter!.textContent = `${currentIndex + 1} / ${sources.length}`;
    }

    function open(idx: number) {
      show(idx);
      lightbox!.hidden = false;
      document.body.style.overflow = "hidden";
    }
    function close() {
      lightbox!.hidden = true;
      document.body.style.overflow = "";
    }

    thumbs.forEach(t => t.addEventListener("click", () => {
      open(parseInt(t.dataset.index ?? "0", 10));
    }));
    lbClose.addEventListener("click", close);
    lbPrev.addEventListener("click", () => show(currentIndex - 1));
    lbNext.addEventListener("click", () => show(currentIndex + 1));
    lightbox.addEventListener("click", e => {
      if (e.target === lightbox) close();
    });
    document.addEventListener("keydown", e => {
      if (lightbox.hidden) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") show(currentIndex - 1);
      if (e.key === "ArrowRight") show(currentIndex + 1);
    });
  }
</script>