---
import Base from "../../layouts/Base.astro"; 
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const achievements = await getCollection("achievements");
  return achievements.map(a => ({ params: { id: a.id }, props: { achievement: a } }));
}

const { achievement } = Astro.props;
const { Content } = await render(achievement);

const formattedDate = new Date(achievement.data.date).toLocaleDateString("en-GB", {
  day: "numeric", month: "long", year: "numeric"
});
const base = import.meta.env.BASE_URL;
---
<Base title={achievement.data.title}>

  <!-- Header -->
  <div style="margin-bottom:1.5rem;">
    <time style="font-size:0.85rem; color:#999;">{formattedDate}</time>
    <h1 style="margin:0.4rem 0 0.3rem;">{achievement.data.title}</h1>
    {achievement.data.subtitle && (
      <p style="font-size:1.05rem; color:#666; font-style:italic; margin:0 0 1rem;">
        {achievement.data.subtitle}
      </p>
    )}
    <div style="display:flex; flex-wrap:wrap; gap:6px;">
      {(Array.isArray(achievement.data.tags)
          ? achievement.data.tags
          : [achievement.data.tags]
        ).map((t: string) => (
        <span style="display:inline-block; background:#e8f0fe; color:#1a5276;
                     border-radius:4px; padding:2px 9px; font-size:0.78rem;">{t}</span>
      ))}
    </div>
  </div>

  <!-- Cover image -->
  {achievement.data.coverImage && (
    <div style="margin-bottom:2rem; border-radius:10px; overflow:hidden;">
      <Image src={achievement.data.coverImage} alt={achievement.data.title}
             width={960} height={420}
             style="width:100%; max-height:420px; object-fit:cover; display:block;" />
    </div>
  )}


  <!-- Body -->
  <div class="card prose" style="margin-bottom:2rem;">
    <Content />
  </div>

  <!-- Gallery -->
  {achievement.data.images && achievement.data.images.length > 0 && (
    <div style="margin-top:2rem;">
      <h2 style="font-size:1.1rem; margin-bottom:1rem;">Gallery</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(240px,1fr)); gap:1rem;">
        {achievement.data.images.map((img: ImageMetadata) => (
          <div style="border-radius:8px; overflow:hidden; aspect-ratio:4/3;">
            <Image src={img} alt="" width={400} height={300}
                   style="width:100%; height:100%; object-fit:cover; display:block;" />
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Back -->
  <div style="margin-top:2.5rem;">
    <a href={`${base}/achievements`}
       style="color:#1a5276; text-decoration:none; font-size:0.9rem;">
      ← Back to Achievements
    </a>
  </div>

</Base>