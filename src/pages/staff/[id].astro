---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";
import { marked } from "marked";

export async function getStaticPaths() {
  const staff = await getCollection("staff");
  return staff.map(p => ({ params: { id: p.id }, props: { person: p } }));
}

const { person } = Astro.props;
const base = import.meta.env.BASE_URL;

const allStaff = await getCollection("staff");
const sidebarLinks = [
  { label: "Laboratoriji",    href: `${base}/laboratories` },
  { label: "Interesne skupine", href: `${base}/interest-groups` },
  {
    label: "Osebje",
    href: `${base}/staff`,
    children: allStaff.map(p => ({
      label: p.data.name,
      href: `${base}/staff/${p.id}`,
    })),
  },
];


const skipFields = new Set([
  'name', 'photo', 'title', 'role', 'email', 'phone',
  'office', 'contactHours', 'linkedin', 'cobiss', 'section',
]);

const knownLabels: Record<string, string> = {
  researchTopics:    "Glavna področja raziskovanja",
  publications:      "Pomembnejše publikacije",
  cv:                "Življenjepis",
  teaching:          "Pedagoško delo",
  projects:          "Projekti",
  editorial:         "Uredništvo",
  awards:            "Nagrade",
  conferenceOrg:     "Organiziranje in vodenje konferenc",
  projectsCollab:    "Mednarodni projekti in sodelovanje",
  reviewerFor:       "Recenzent pri revijah",
  certificates:      "Certifikati",
  zaposlitev:        "Zaposlitev",
  kratkaBiografija:  "Kratka biografija",
  raziskovalnoDelo:  "Raziskovalno delo",
  delovneIzkusnje:   "Delovne izkušnje",
  izobrazevanjeVTujini: "Izobraževanja v tujini",
  studijInRaziskovanjeVTujini: "Študij in raziskovanje v tujini",
  studijskeIzmenjave: "Študijske izmenjave",
  izmenjave:         "Izmenjave",
  vabljenaPredavanja: "Vabljena predavanja",
  delavniceInVabljenaPredavanja: "Delavnice in vabljena predavanja",
  izvedbaDelavnic:   "Izvedba delavnic",
  posebnaVabila:     "Posebna vabila",
  organiziranjeInVodenjeKonferenc: "Organiziranje in vodenje konferenc",
  sodelovanjePriKonferencah: "Sodelovanje pri konferencah",
  konferencneAktivnosti: "Konferenčne aktivnosti",
  projektneAktivnosti: "Projektne aktivnosti",
  vodjaKoordinatorProjekta: "Vodja/Koordinator projekta",
  sodelovanjePriProjektu: "Sodelovanje pri projektu",
  recenzijskeInUredniskeAktivnosti: "Recenzijske in uredniške aktivnosti",
  pedagoskaDejavnost: "Pedagoška dejavnost",
  mentorstva:        "Mentorstva",
  clanstvo:          "Članstvo",
  clanicaOdborov:    "Članica odborov",
  polozaji:          "Položaji",
  sodelovanjeVDelovihSkupinah: "Sodelovanje v delovnih skupinah",
  mednarodnaDejavnost: "Mednarodna dejavnost",
  vMedijih:          "V medijih",
  izobraževanje:     "Izobraževanje",
};

function camelToLabel(key: string): string {
  if (knownLabels[key]) return knownLabels[key];
  return key
    .replace(/([A-Z])/g, ' $1')
    .replace(/^./, s => s.toUpperCase())
    .trim();
}

const sections = Object.entries(person.data)
  .filter(([key, value]) => !skipFields.has(key) && value && typeof value === 'string' && value.trim() !== '')
  .map(([key, value]) => ({ key, label: camelToLabel(key), value: value as string }));
---
<Base title={person.data.name} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{person.data.name}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div style="display:flex; gap:1.6rem; align-items:flex-start; flex-wrap:wrap; margin-bottom:1.5rem;">
      {person.data.photo
        ? <Image src={person.data.photo} alt={person.data.name} width={130} height={130}
                 style="width:130px; height:130px; object-fit:cover; border-radius:4px;
                        border:1px solid var(--border); flex-shrink:0;" />
        : <div style="width:130px; height:130px; border-radius:4px; background:var(--um-blue-light);
                      display:flex; align-items:center; justify-content:center;
                      font-size:2.6rem; color:var(--um-blue); font-weight:700; flex-shrink:0;">
            {person.data.name.charAt(0)}
          </div>
      }
      <div style="flex:1; min-width:220px;">
        {person.data.title && (
          <p style="font-size:0.92rem; color:var(--muted); font-style:italic; margin-bottom:0.2rem;">
            {person.data.title}
          </p>
        )}
        <p style="color:var(--text); margin-bottom:0.85rem;">{person.data.role}</p>
        <ul class="contact-info" style="font-size:0.92rem;">
          {person.data.email && <li><strong>E-pošta:</strong> <a href={`mailto:${person.data.email}`}>{person.data.email}</a></li>}
          {person.data.phone && <li><strong>Telefon:</strong> {person.data.phone}</li>}
          {person.data.office && <li><strong>Prostor:</strong> {person.data.office}</li>}
          {person.data.contactHours && <li><strong>Govorilne ure:</strong> <a href={person.data.contactHours} target="_blank">povezava</a></li>}
          {person.data.linkedin && <li><strong>LinkedIn:</strong> <a href={person.data.linkedin} target="_blank">povezava</a></li>}
        </ul>
      </div>
    </div>

    {sections.map(({ key, label, value }) => (
      <div style="margin-bottom:1.4rem;">
        <div class="section-heading"><h3>{label}</h3></div>
        <div class="prose" set:html={marked.parse(value)} />
      </div>
    ))}

    {person.data.cobiss && (
      <div class="external-link">
        <div class="section-heading" style="margin-top:0;"><h3>Publikacije</h3></div>
        <p style="margin-bottom:0.5rem;">Celotno poročilo je dostopno na COBISS.</p>
        <a href={person.data.cobiss} target="_blank">Ogled na COBISS →</a>
      </div>
    )}

  </div>

  <SectionNews tag="student" label="Zadnje novice" />

</Base>