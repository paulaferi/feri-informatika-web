---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const staff = await getCollection("staff");
  return staff.map(p => ({ params: { id: p.id }, props: { person: p } }));
}

const { person } = Astro.props;

type Section = { key: keyof typeof person.data; label: string };
const sections: Section[] = [
  { key: "researchTopics",  label: "Glavne raziskovalne teme" },
  { key: "publications",    label: "Seznam izbranih publikacij" },
  { key: "cv",              label: "CV" },
  { key: "teaching",        label: "Poučevanje" },
  { key: "projects",        label: "Vodja projekta / koordinator" },
  { key: "editorial",       label: "Urednik" },
  { key: "awards",          label: "Nagrade" },
  { key: "conferenceOrg",   label: "Organizacija konference" },
  { key: "projectsCollab",  label: "Projekti Sodelovanje" },
  { key: "reviewerFor",     label: "Recenzent za znanstvene revije" },
  { key: "certificates",    label: "Potrdila" },
];

import { marked } from "marked";
---
<Base title={person.data.name}>

  <!-- Header -->
  <div style="display:flex; gap:2rem; align-items:flex-start; flex-wrap:wrap; margin-bottom:2rem;">
    {person.data.photo && (
      <Image src={person.data.photo} alt={person.data.name}
             width={160} height={160}
             style="width:160px; height:160px; object-fit:cover; border-radius:8px;
                    border:1px solid #ddd; flex-shrink:0;" />
    )}
    {!person.data.photo && (
      <div style="width:160px; height:160px; border-radius:8px; background:#e8f0fe;
                  display:flex; align-items:center; justify-content:center;
                  font-size:3rem; color:#1a5276; flex-shrink:0;">
        {person.data.name.charAt(0)}
      </div>
    )}
    <div style="flex:1; min-width:220px;">
      <h1 style="margin-bottom:0.2rem;">{person.data.name}</h1>
      {person.data.title && (
        <p style="font-size:0.95rem; color:#666; margin-bottom:0.3rem;">{person.data.title}</p>
      )}
      <p style="color:#444; margin-bottom:1rem;">{person.data.role}</p>
      <ul class="contact-info">
        {person.data.email && (
          <li>E-mail: <a href={`mailto:${person.data.email}`}>{person.data.email}</a></li>
        )}
        {person.data.phone    && <li>Telefon: {person.data.phone}</li>}
        {person.data.office   && <li>Soba: {person.data.office}</li>}
        {person.data.contactHours && (
          <li>Ure za stike: <a href={person.data.contactHours} target="_blank">link</a></li>
        )}
        {person.data.linkedin && (
          <li>LinkedIn: <a href={person.data.linkedin} target="_blank">link</a></li>
        )}
      </ul>
    </div>
  </div>

  <!-- Dynamic sections -->
  {sections.map(({ key, label }) => {
    const value = person.data[key];
    if (!value || value === "") return null;
    return (
      <div class="card" style="margin-bottom:1rem;">
        <h2 style="margin-top:0; font-size:1.1rem; border-bottom:1px solid #eee;
                   padding-bottom:0.5rem; margin-bottom:0.8rem;">{label}</h2>
        <div class="prose" set:html={marked.parse(value as string)} />
      </div>
    );
  })}

  <!-- Publications COBISS -->
  {person.data.cobiss && (
    <div class="card">
      <h2 style="margin-top:0; font-size:1.1rem;">Publikacije</h2>
      <p>Poln poročilo je na voljo na COBISS:</p>
      <a href={person.data.cobiss} target="_blank" style="color:#0066cc;">
        Oglej na COBISS →
      </a>
    </div>
  )}

</Base>