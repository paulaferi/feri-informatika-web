---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";
import { marked } from "marked";

export async function getStaticPaths() {
  const staff = await getCollection("staff");
  return staff.map(p => ({ params: { id: p.id }, props: { person: p } }));
}

const { person } = Astro.props;
const base = import.meta.env.BASE_URL;

const allStaff = await getCollection("staff");
const sidebarLinks = [
  { label: "Laboratories",    href: `${base}/laboratories` },
  { label: "Interest Groups", href: `${base}/interest-groups` },
  {
    label: "Staff",
    href: `${base}/staff`,
    children: allStaff.map(p => ({
      label: p.data.name,
      href: `${base}/staff/${p.id}`,
    })),
  },
];

type Section = { key: keyof typeof person.data; label: string };
const sections: Section[] = [
  { key: "researchTopics",  label: "Main Research Topics" },
  { key: "publications",    label: "Selected Publications" },
  { key: "cv",              label: "Curriculum Vitae" },
  { key: "teaching",        label: "Teaching" },
  { key: "projects",        label: "Project Leader / Coordinator" },
  { key: "editorial",       label: "Editorial Activity" },
  { key: "awards",          label: "Awards" },
  { key: "conferenceOrg",   label: "Conference Organization" },
  { key: "projectsCollab",  label: "Project Collaboration" },
  { key: "reviewerFor",     label: "Reviewer for Journals" },
  { key: "certificates",    label: "Certificates" },
];
---
<Base title={person.data.name} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{person.data.name}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div style="display:flex; gap:1.6rem; align-items:flex-start; flex-wrap:wrap; margin-bottom:1.5rem;">
      {person.data.photo
        ? <Image src={person.data.photo} alt={person.data.name} width={130} height={130}
                 style="width:130px; height:130px; object-fit:cover; border-radius:4px;
                        border:1px solid var(--border); flex-shrink:0;" />
        : <div style="width:130px; height:130px; border-radius:4px; background:var(--um-blue-light);
                      display:flex; align-items:center; justify-content:center;
                      font-size:2.6rem; color:var(--um-blue); font-weight:700; flex-shrink:0;">
            {person.data.name.charAt(0)}
          </div>
      }
      <div style="flex:1; min-width:220px;">
        {person.data.title && (
          <p style="font-size:0.92rem; color:var(--muted); font-style:italic; margin-bottom:0.2rem;">
            {person.data.title}
          </p>
        )}
        <p style="color:var(--text); margin-bottom:0.85rem; font-size:1rem;">{person.data.role}</p>
        <ul class="contact-info" style="font-size:0.92rem;">
          {person.data.email && <li><strong>Email:</strong> <a href={`mailto:${person.data.email}`}>{person.data.email}</a></li>}
          {person.data.phone && <li><strong>Telephone:</strong> {person.data.phone}</li>}
          {person.data.office && <li><strong>Office:</strong> {person.data.office}</li>}
          {person.data.contactHours && <li><strong>Contact hours:</strong> <a href={person.data.contactHours} target="_blank">link</a></li>}
          {person.data.linkedin && <li><strong>LinkedIn:</strong> <a href={person.data.linkedin} target="_blank">link</a></li>}
        </ul>
      </div>
    </div>

    {sections.map(({ key, label }) => {
      const value = person.data[key];
      if (!value || value === "") return null;
      return (
        <div style="margin-bottom:1.4rem;">
          <div class="section-heading"><h3>{label}</h3></div>
          <div class="prose" set:html={marked.parse(value as string)} />
        </div>
      );
    })}

    {person.data.cobiss && (
      <div class="external-link">
        <div class="section-heading" style="margin-top:0;"><h3>Publications</h3></div>
        <p style="margin-bottom:0.5rem;">The full report is available on COBISS.</p>
        <a href={person.data.cobiss} target="_blank">View on COBISS →</a>
      </div>
    )}

  </div>

  <SectionNews tag="student" label="Latest News" />

</Base>
