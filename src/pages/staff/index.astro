---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const staff = await getCollection("staff");
const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Laboratories",    href: `${base}/laboratories` },
  { label: "Interest Groups", href: `${base}/interest-groups` },
  { label: "Staff",           href: `${base}/staff` },
];
---
<Base title="Staff" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Staff</h1>
  <div class="page-title-rule"></div>
  <p class="page-subtitle">Academic and research staff of the Institute of Informatics</p>

  <div class="staff-grid">
    {staff.map(p => (
      <a href={`${base}/staff/${p.id}`} class="staff-card">
        <div class="staff-avatar">
          {p.data.photo
            ? <Image src={p.data.photo} alt={p.data.name} width={76} height={76} />
            : <span>{p.data.name.charAt(0)}</span>
          }
        </div>
        <p class="staff-name">{p.data.name}</p>
        {p.data.title && <p class="staff-academic-title">{p.data.title}</p>}
        <p class="staff-role">{p.data.role}</p>
        <div class="staff-divider"></div>
        {p.data.email && <p class="staff-email">{p.data.email}</p>}
      </a>
    ))}
  </div>

  {staff.length === 0 && (
    <div class="card"><p class="empty-state" style="margin:0;">No staff members listed yet.</p></div>
  )}

  <SectionNews tag="student" label="Latest News" />

</Base>
