---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const programmes = await getCollection("studyProgrammes");
const projects   = await getCollection("studentProjects");
---
<Base title="Studies IPT and ITK">
  <h1>Študij IPT in ITK</h1>
  <p>
    Inštitut ponuja dodiplomske in podiplomske študijske programe na področju
    informacijskih tehnologij (IPT) ter informacijskih in komunikacijskih tehnologij (ITK).
  </p>

  <h2>Study Programmes</h2>
  {programmes.map(p => (
    <div class="card">
      <h3><a href={`${base}/studies/programmes/${p.id}`}>{p.data.title}</a></h3>
      <p class="meta">
        {p.data.type} · {p.data.duration} let{p.data.duration > 1 ? "i" : ""} · {p.data.ects} ECTS
        {p.data.scope && ` · ${p.data.scope}`}
      </p>
      {p.data.externalUrl && (
        <a href={p.data.externalUrl} target="_blank" style="font-size:0.85rem; color:#0066cc;">
          Polni podatki o programu na moja.um.si →
        </a>
      )}
    </div>
  ))}

  <h2>Študentski projekti</h2>
  {projects.map(p => (
    <div class="card">
      <h3><a href={`${base}/studies/student-projects/${p.id}`}>{p.data.title}</a></h3>
      <p class="meta">{p.data.student} · {p.data.year}</p>
      <p>{p.data.description}</p>
    </div>
  ))}

  <SectionNews tag="student" label="Student News" />
</Base>