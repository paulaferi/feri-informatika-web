---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("studentProjects");
  return projects.map(p => ({ params: { id: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;

const allProjects = await getCollection("studentProjects");

const sidebarLinks = [
  { label: "Study Programmes", href: `${base}/studies/programmes` },
  {
    label: "Student Activities",
    href: `${base}/studies/student-projects`,
    children: allProjects.map(p => ({
      label: p.data.title,
      href: `${base}/studies/student-projects/${p.id}`,
    })),
  },
];
---
<Base title={project.data.title} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{project.data.title}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="intro"><p>{project.data.description}</p></div>

    <div class="section-heading"><h3>Project Information</h3></div>
    <ul class="detail-list">
      <li><span><strong>Student(s):</strong> {project.data.student}</span></li>
      <li><span><strong>Year:</strong> {project.data.year}</span></li>
    </ul>

    {project.data.body && (
      <div>
        <div class="section-heading"><h3>Details</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {project.data.externalUrl && (
      <div class="external-link">
        <a href={project.data.externalUrl} target="_blank">View on praktik.um.si →</a>
      </div>
    )}

  </div>

  <a href={`${base}/studies/student-projects`} class="back-link">← Back to Student Activities</a>

  <SectionNews tag="student" label="Latest News" />

</Base>
