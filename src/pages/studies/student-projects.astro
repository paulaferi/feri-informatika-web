---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const projects = await getCollection("studentProjects");

const sidebarLinks = [
  { label: "Study Programmes",   href: `${base}/studies/programmes` },
  { label: "Student Activities", href: `${base}/studies/student-projects` },
];
---
<Base title="Student Activities" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Student Activities</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>Students at the Institute of Informatics take part in numerous projects and activities that complement formal education and develop practical skills.</p>
    </div>

    <div class="section-heading"><h3>Projects</h3></div>
    <ul class="arrow-list">
      {projects.map(p => (
        <li>
          <span class="arrow-icon">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <a href={`${base}/studies/student-projects/${p.id}`}>
            {p.data.title}
            <span style="font-size:0.8rem; color:var(--muted); font-weight:400; margin-left:5px;">
              ({p.data.student} · {p.data.year})
            </span>
          </a>
        </li>
      ))}
      {projects.length === 0 && <li class="empty-state">No student projects listed yet.</li>}
    </ul>
  </div>

  <SectionNews tag="student" label="Latest News" />

</Base>
