---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const programmes = await getCollection("studyProgrammes");
  return programmes.map(p => ({ params: { id: p.id }, props: { programme: p } }));
}

const { programme } = Astro.props;
const { Content } = await render(programme);
const base = import.meta.env.BASE_URL;

const allProgrammes = await getCollection("studyProgrammes");

const sidebarLinks = [
  {
    label: "Študijski programi",
    href: `${base}/studies/programmes`,
    children: allProgrammes.map(p => ({
      label: p.data.title,
      href: `${base}/studies/programmes/${p.id}`,
    })),
  },
  { label: "Študentske dejavnosti", href: `${base}/studies/student-projects` },
];
---
<Base title={programme.data.title} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{programme.data.title}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    {programme.data.scope && (
      <div class="intro"><p>{programme.data.scope}</p></div>
    )}

    <div class="section-heading"><h3>Informacije o programu</h3></div>
    <ul class="detail-list">
      <li><span><strong>Vrsta:</strong> {programme.data.type}</span></li>
      <li><span><strong>Trajanje:</strong> {programme.data.duration} {programme.data.duration === 1 ? "leto" : "leta"}</span></li>
      <li><span><strong>ECTS krediti:</strong> {programme.data.ects}</span></li>
    </ul>

    {programme.data.body && (
      <div>
        <div class="section-heading"><h3>Učni načrt &amp; Splošne informacije</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {programme.data.externalUrl && (
      <div class="external-link">
        <a href={programme.data.externalUrl} target="_blank">Oglejte si program na moja.um.si →</a>
      </div>
    )}

  </div>

  <a href={`${base}/studies/programmes`} class="back-link">← Nazaj na študijske programe</a>

  <SectionNews tag="student" label="Najnovejše novice" />

</Base>
