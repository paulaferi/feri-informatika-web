---
import Base from "../../layouts/Base.astro";
import NewsCard from "../../components/NewsCard.astro";
import { getCollection } from "astro:content";

const allNews = (await getCollection("news"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const tags = ["student", "conference", "scientific", "professional",
              "project", "awards", "interest-groups"];
---
<Base title="News">
  <h1>Novice</h1>

  <div id="tag-filters" style="margin-bottom:1.5rem; display:flex; flex-wrap:wrap; gap:8px; align-items:center;">
    <span style="font-size:0.85rem; color:#888; margin-right:4px;">Filter:</span>
    <button data-tag="" class="tag-btn active">Vse</button>
    {tags.map(t => <button data-tag={t} class="tag-btn">{t}</button>)}
  </div>

  <p id="empty-msg" style="color:#888; display:none;">Za to oznako ni novic.</p>

  <div id="news-grid" class="news-grid">
    {allNews.map(n => (
      <div class="news-item" data-tags={Array.isArray(n.data.tags) ? n.data.tags.join(",") : n.data.tags}>
        <NewsCard
          id={n.id}
          title={n.data.title}
          date={n.data.date.toString()}
          summary={n.data.summary}
          coverImage={n.data.coverImage}
        />
      </div>
    ))}
  </div>
</Base>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .tag-btn {
    padding: 4px 14px;
    border-radius: 20px;
    border: 1px solid #1a5276;
    background: transparent;
    color: #1a5276;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all .15s;
  }
  .tag-btn.active {
    background: #1a5276;
    color: #fff;
  }
  .tag-btn:hover { opacity: 0.8; }
</style>

<script>
  const buttons  = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const items    = document.querySelectorAll<HTMLElement>(".news-item");
  const emptyMsg = document.getElementById("empty-msg")!;

  function filter(tag: string) {
    buttons.forEach(b => b.classList.toggle("active", b.dataset.tag === tag));
    let visible = 0;
    items.forEach(item => {
      const itemTags = item.dataset.tags?.split(",") ?? [];
      const show = tag === "" || itemTags.includes(tag);
      item.style.display = show ? "block" : "none";
      if (show) visible++;
    });
    emptyMsg.style.display = visible === 0 ? "block" : "none";
  }

  buttons.forEach(b => b.addEventListener("click", () => filter(b.dataset.tag ?? "")));
</script>