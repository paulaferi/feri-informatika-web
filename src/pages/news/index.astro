---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const allNews = (await getCollection("news"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL;
const tags = ["student", "conference", "scientific", "professional",
              "project", "awards", "interest-groups"];
const tagLabels: Record<string, string> = {
  student: "Študentsko", conference: "Konferenca", scientific: "Znanstveno",
  professional: "Strokovno", project: "Projekt", awards: "Nagrade",
  "interest-groups": "Interesne skupine",
};
---
<Base title="Novice" wide>

  <h1 class="page-title">Novice</h1>
  <div class="page-title-rule"></div>

  <div class="filter-bar">
    <span class="filter-label">Filter</span>
    <button data-tag="" class="tag-btn active">Vse</button>
    {tags.map(t => <button data-tag={t} class="tag-btn">{tagLabels[t] ?? t}</button>)}
  </div>

  <p id="empty-msg" class="empty-state" style="display:none;">Ni novic za ta tag.</p>

  <div id="grid" class="card-grid">
    {allNews.map(n => (
      <a href={`${base}/news/${n.id}`} class="grid-card news-item"
         data-tags={Array.isArray(n.data.tags) ? n.data.tags.join(",") : String(n.data.tags)}>
        <div class="grid-card-image">
          {(() => {
            const cover = n.data.coverImage ?? (n.data.images && n.data.images[0]);
            return cover
              ? <Image src={cover} alt={n.data.title} />
              : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
          })()}
        </div>
        <div class="grid-card-accent"></div>
        <div class="grid-card-body">
          <time class="grid-card-date">
            {new Date(n.data.date).toLocaleDateString("sl-SI", {
              day: "numeric", month: "long", year: "numeric"
            })}
          </time>
          <h3 class="grid-card-title">{n.data.title}</h3>
          <p class="grid-card-summary">{n.data.summary}</p>
        </div>
      </a>
    ))}
  </div>

  {allNews.length === 0 && (
    <div class="card"><p class="empty-state" style="margin:0;">Ni novic na seznamu.</p></div>
  )}

</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const items   = document.querySelectorAll<HTMLElement>(".news-item, .achievement-item");
  const empty   = document.getElementById("empty-msg")!;
  const langSwitcher = document.getElementById("lang-switcher-link") as HTMLAnchorElement | null;

  function updateLangSwitcher(tag: string) {
    if (!langSwitcher) return;
    const url = new URL(langSwitcher.href, window.location.origin);
    if (tag) url.searchParams.set("tag", tag);
    else url.searchParams.delete("tag");
    langSwitcher.href = url.toString();
  }

  function filter(tag: string) {
    buttons.forEach(b => b.classList.toggle("active", b.dataset.tag === tag));
    let visible = 0;
    items.forEach(item => {
      const itemTags = item.dataset.tags?.split(",").map(t => t.trim()) ?? [];
      const show = tag === "" || itemTags.includes(tag);
      item.style.display = show ? "flex" : "none";
      if (show) visible++;
    });
    empty.style.display = visible === 0 ? "block" : "none";

    const url = new URL(window.location.href);
    if (tag) url.searchParams.set("tag", tag);
    else url.searchParams.delete("tag");
    history.replaceState(null, "", url.toString());
    updateLangSwitcher(tag);
  }

  const initialTag = new URLSearchParams(window.location.search).get("tag") ?? "";
  if (initialTag) filter(initialTag);
  updateLangSwitcher(initialTag);

  buttons.forEach(b => b.addEventListener("click", () => filter(b.dataset.tag ?? "")));
</script>