---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const allNews = (await getCollection("news"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL;

const tags = ["staff", "conference", "scientific", "professional",
              "project", "awards", "interest-groups", "student"];

const newsData = allNews.map(n => ({
  id: n.id,
  title: n.data.title,
  date: new Date(n.data.date).toLocaleDateString("es-ES"),
  summary: n.data.summary,
  tags: n.data.tags,
  url: `${base}/news/${n.id}`,
}));
---
<Base title="News">
  <h1>News</h1>

  <div id="tag-filters" style="margin-bottom:1.5rem; display:flex; flex-wrap:wrap; gap:8px; align-items:center;">
    <span style="font-size:0.85rem; color:#888; margin-right:4px;">Filter:</span>
    <button data-tag="" class="tag-btn active">All</button>
    {tags.map(t => <button data-tag={t} class="tag-btn">{t}</button>)}
  </div>

  <p id="empty-msg" style="color:#888; display:none;">
    No news available with this tag.
  </p>

  <div id="news-list">
    {newsData.map(n => (
      <div class="card news-item" data-tags={n.tags.join(",")}>
        <div class="meta">{n.date} </div>
        <h2><a href={n.url}>{n.title}</a></h2>
        <p>{n.summary}</p>
        <div style="margin-top:8px;">
          {n.tags.map((t: string) => (
            <button class="tag-btn-inline" data-tag={t}>{t}</button>
          ))}
        </div>
      </div>
    ))}
  </div>
</Base>

<style>
  .tag-btn {
    padding: 4px 14px;
    border-radius: 20px;
    border: 1px solid #1a5276;
    background: transparent;
    color: #1a5276;
    font-size: 0.82rem;
    cursor: pointer;
  }
  .tag-btn.active {
    background: #1a5276;
    color: #fff;
  }
  .tag-btn-inline {
    display: inline-block;
    background: #e8f0fe;
    color: #1a5276;
    border: none;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 0.78rem;
    margin-right: 4px;
    cursor: pointer;
  }
  .tag-btn-inline:hover, .tag-btn:hover {
    opacity: 0.8;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const inlineBtns = document.querySelectorAll<HTMLButtonElement>(".tag-btn-inline");
  const items = document.querySelectorAll<HTMLElement>(".news-item");
  const emptyMsg = document.getElementById("empty-msg")!;

  let activeTag = "";

  function filter(tag: string) {
    activeTag = tag;

    buttons.forEach(b => b.classList.toggle("active", b.dataset.tag === tag));

    let visible = 0;
    items.forEach(item => {
      const itemTags = item.dataset.tags?.split(",") ?? [];
      const show = tag === "" || itemTags.includes(tag);
      item.style.display = show ? "block" : "none";
      if (show) visible++;
    });

    emptyMsg.style.display = visible === 0 ? "block" : "none";
  }

  buttons.forEach(b => b.addEventListener("click", () => filter(b.dataset.tag ?? "")));
  inlineBtns.forEach(b => b.addEventListener("click", () => filter(b.dataset.tag ?? "")));
</script>