---
import Base from "../../layouts/Base.astro";
import { Image } from "astro:assets";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map(n => ({ params: { id: n.id }, props: { article: n } }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const base = import.meta.env.BASE_URL;
---
<Base title={article.data.title}>

  <h1 class="page-title">{article.data.title}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <p class="meta" style="margin-bottom:0.75rem;">
      {new Date(article.data.date).toLocaleDateString("en-GB", {
        day: "numeric", month: "long", year: "numeric"
      })}
    </p>

    <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:1.25rem;">
      {(Array.isArray(article.data.tags) ? article.data.tags : [String(article.data.tags)]).map((t: string) => (
        <span class="tag">{t}</span>
      ))}
    </div>

    {article.data.coverImage && (
      <div style="margin-bottom:1.5rem; border-radius:4px; overflow:hidden;">
        <Image src={article.data.coverImage} alt={article.data.title}
               width={900} height={400}
               style="width:100%; max-height:400px; object-fit:cover; display:block;" />
      </div>
    )}

    <div class="intro"><p>{article.data.summary}</p></div>

    <div class="prose"><Content /></div>

    {article.data.images && article.data.images.length > 0 && (
      <div style="margin-top:1.75rem;">
        <div class="section-heading"><h3>Gallery</h3></div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px,1fr)); gap:0.85rem;">
          {article.data.images.map((img: ImageMetadata) => (
            <div style="border-radius:4px; overflow:hidden; aspect-ratio:4/3; border:1px solid var(--border);">
              <Image src={img} alt="" width={400} height={300}
                     style="width:100%; height:100%; object-fit:cover; display:block;" />
            </div>
          ))}
        </div>
      </div>
    )}

  </div>

  <a href={`${base}/news`} class="back-link">← Back to News</a>

</Base>
