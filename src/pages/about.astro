---
import Base from "../layouts/Base.astro";
import SectionNews from "../components/SectionNews.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { readFileSync } from "fs";
import { resolve } from "path";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Laboratoriji",    href: `${base}/laboratories` },
  { label: "Zainteresirane skupine", href: `${base}/interest-groups` },
  { label: "Osebje",           href: `${base}/staff` },
];

let highlightedNewsIds: string[]        = [];
let highlightedAchievementsIds: string[] = [];
let highlightedProjectsIds: string[]    = [];

try {
  const configPath = resolve("src/content/config/highlighted.json");
  const raw = readFileSync(configPath, "utf-8");
  const config = JSON.parse(raw);
  highlightedNewsIds        = config.news         ?? [];
  highlightedAchievementsIds = config.achievements ?? [];
  highlightedProjectsIds    = config.projects      ?? [];
} catch {
}

function normalizeId(str: string): string {
  return str
    .toLowerCase()
    .replace(/[\u{1F000}-\u{1FFFF}]/gu, '')
    .replace(/[\u{2600}-\u{27BF}]/gu, '')
    .replace(/[»«""''–—]/g, '')
    .replace(/[čć]/g, 'c')
    .replace(/[šś]/g, 's')
    .replace(/[žź]/g, 'z')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/[^\w-]/g, '')
    .trim();
}

function findById<T extends { id: string; slug?: string }>(
  collection: T[],
  ids: string[]
): T[] {
  return ids
    .map(id => {
      const norm = normalizeId(id);
      return collection.find(n =>
        n.id === id ||
        n.slug === id ||
        normalizeId(n.id) === norm ||
        normalizeId(n.slug ?? '') === norm
      );
    })
    .filter(Boolean) as T[];
}

const allNews         = await getCollection("news");
const allAchievements = await getCollection("achievements");
const allProjects     = await getCollection("projects");

const highlightedNews         = findById(allNews, highlightedNewsIds).slice(0, 3);
const highlightedAchievements = findById(allAchievements, highlightedAchievementsIds).slice(0, 3);
const highlightedProjects     = findById(allProjects, highlightedProjectsIds).slice(0, 3);
---
<Base title="About the Institute" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Inštitut za Informatiko</h1>
  <div class="page-title-rule"></div>
  <p class="page-subtitle">
    Fakulteta za elektrotehniko, računalništvo in informatiko · Univerza v Mariboru
  </p>

  
  <div class="card">
    <div class="intro">
      <p>Inštitut za Informatiko opravlja raziskave v področju informatike, ki so usmerjene k učinkovitem razvoju in upravljanju varnih, inteligentnih in zanesljivih informacijskih sistemov, rešitev in storitev. Osredotočenje raziskovalnega dela je na inženirstvo podatkov in velike podatke, umetno inteligenco in inteligentne sisteme, kibernetsko varnost in zasebnost, inženirstvo programske opreme in agilni razvoj ter avtomatizacija procesov, centralizirane in decentralizirane arhitekturo in sisteme.</p>
    </div>

    <p>Na Univerzi v Mariboru, Inštitut za Informatiko je glavni ponudnik izobraževanja v podiplomskih in dodiplomskih programih v področju Informatike in Tehnologij Podatkov.</p>
    <p>Kot del naše raziskovalne dejavnosti v področju arhitektur informacijskih sistemov, raziskujemo decentralizirane, oblak, velike podatke, mikroservise in serverless arhitekturo; skladišča podatkov, jezera podatkov in prostori podatkov, ter decentralizirane omrežja umetne inteligence.</p>
    <p>Raziskave v širšem področju inteligentnih sistemov se lotijo izzivov rastoče mere, kompleksnosti in večmodnosti podatkov, odpravljene in nepravične odločitve modelov umetne inteligence, potrebe po prilagojenih rešitvah učenja strojnosti ter izzivov modelov v proizvodnih okoljih (MLOps/AI engineering).</p>
    <p>Razvijamo napredne pristope k razvoju informacijskih sistemov z uporabo inteligentnih komponent v oblaku, pri čemer se posebej osredotočamo na prakse DevSecOps, vključno z avtomatizacijo CI/CD, ki zagotavlja neprekinjeno testiranje, uveljavljanje praks za varno pisanje kode ter ocenjevanje kakovosti na podlagi meril.</p>
    <p>Raziskave na področju kibernetske varnosti in zasebnosti se osredotočajo na ocenjevanje pristopov za izboljšanje varnosti sistemov in zasebnosti, sodobne centralizirane in decentralizirane metode avtentifikacije ter proaktivne pristope k odkrivanju in preprečevanju kibernetskih groženj, vključno z uporabo umetne inteligence. V okviru inštituta deluje certificiran laboratorij za digitalno forenziko.</p>
    <p>Novi modeli in metode za raziskave uporabniške izkušnje (UX) prispevajo k izboljšanju kakovosti uporabniške izkušnje, zlasti z uporabo naprednih inteligentnih orodij in pristopov, vključno z vključujočo uporabniško izkušnjo ter uporabniško izkušnjo v kontekstu razlagljive umetne inteligence (XAI).</p>
    <p style="margin-bottom:0;">Raziskovalno delo na področju upravljanja poslovnih procesov se ukvarja z dinamičnim pogledom na sodobne informacijske rešitve, ki temeljijo na naprednih pristopih k modeliranju procesov, prožnem in nestrukturiranem modeliranju procesov ter procesnemu rudarjenju.</p>

    <div style="margin-top:1.6rem; padding-top:1.3rem; border-top:1px solid var(--border);">
      <div class="section-heading"><h3>Kontakt</h3></div>
      <ul class="contact-info">
        <li><strong>E-pošta:</strong> <a href="mailto:informatika@um.si">informatika@um.si</a></li>
        <li><strong>Naslov:</strong> Koroška cesta 46, 2000 Maribor, Slovenia</li>
        <li><strong>Telefon:</strong> (02) 220 7359</li>
        <li><strong>Spletna stran:</strong> <a href="https://ii.feri.um.si" target="_blank">ii.feri.um.si</a></li>
      </ul>
    </div>
  </div>
  <SectionNews tag="interest-groups" label="Najnovejše novice" />

</Base>