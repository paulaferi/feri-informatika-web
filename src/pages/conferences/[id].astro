---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const conferences = await getCollection("conferences");
  return conferences.map(c => ({ params: { id: c.id }, props: { conference: c } }));
}

const { conference } = Astro.props;
const { Content } = await render(conference);
const base = import.meta.env.BASE_URL;

const allConferences = (await getCollection("conferences"))
  .sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime());

const sidebarLinks = allConferences.map(c => ({
  label: c.data.acronym ?? c.data.name,
  href: `${base}/conferences/${c.id}`,
}));
---
<Base title={conference.data.name} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">
    {conference.data.name}
    {conference.data.acronym && (
      <span style="font-size:1rem; color:var(--muted); font-weight:400;">({conference.data.acronym})</span>
    )}
  </h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="intro"><p>{conference.data.description}</p></div>

    {(conference.data.date || conference.data.location) && (
      <div>
        <div class="section-heading"><h3>Details</h3></div>
        <ul class="detail-list">
          {conference.data.date && (
            <li><span><strong>Date:</strong> {new Date(conference.data.date).toLocaleDateString("en-GB")}</span></li>
          )}
          {conference.data.location && (
            <li><span><strong>Location:</strong> {conference.data.location}</span></li>
          )}
        </ul>
      </div>
    )}

    {conference.data.body && (
      <div>
        <div class="section-heading"><h3>About</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {conference.data.url && (
      <div class="external-link">
        <a href={conference.data.url} target="_blank">Conference website →</a>
      </div>
    )}

  </div>

  <a href={`${base}/conferences`} class="back-link">← Back to Conference Activities</a>

  <SectionNews tag="conference" label="Latest News" />

</Base>
