---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const conferences = (await getCollection("conferences"))
  .sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime());

const sidebarLinks = conferences.map(c => ({
  label: c.data.acronym ?? c.data.name,
  href: `${base}/conferences/${c.id}`,
}));
---
<Base title="Konferenčne dejavnosti" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Konferenčne dejavnosti</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro" style="margin-bottom:0;">
      <p>Inštitut za informatiko aktivno organizira in sodeluje na mednarodnih znanstvenih konferencah v področju informatike in računalništva.</p>
    </div>
  </div>

  {conferences.length === 0 && (
    <div class="card"><p class="empty-state" style="margin:0;">Konferenc še ni na seznamu.</p></div>
  )}

  {conferences.map(c => (
    <div class="card">
      <div class="section-heading">
        <h3>
          <a href={`${base}/conferences/${c.id}`} style="text-decoration:none;">
            {c.data.name}
            {c.data.acronym && (
              <span style="color:var(--muted); font-weight:400;"> ({c.data.acronym})</span>
            )}
          </a>
        </h3>
      </div>
      {(c.data.date || c.data.location) && (
        <p class="meta" style="margin-bottom:0.5rem;">
          {c.data.date && new Date(c.data.date).toLocaleDateString("en-GB")}
          {c.data.location && ` · ${c.data.location}`}
        </p>
      )}
      <p style="margin-bottom:0.5rem;">{c.data.description}</p>
      {c.data.url && (
        <a href={c.data.url} target="_blank" style="font-size:0.86rem; font-weight:600;">
          Spletna stran konference →
        </a>
      )}
    </div>
  ))}

  <SectionNews tag="conference" label="Najnovejše novice" />

</Base>
