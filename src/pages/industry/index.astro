---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const partners     = await getCollection("industryPartners");
const achievements = await getCollection("achievements");
const base = import.meta.env.BASE_URL;

const industryAchievements = achievements.filter(a => {
  const tags = Array.isArray(a.data.tags) ? a.data.tags : [a.data.tags];
  return tags.includes("professional");
});
---
<Base title="Industry">
  <h1>Industrija</h1>

  <h2>Kdo sodelujemo z</h2>
  {partners.length === 0 && <p class="meta">Ni še dodanih partnerjev.</p>}
  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1rem; margin-bottom:2rem;">
    {partners.map(p => (
      <div class="card" style="text-align:center;">
        {p.data.logo && (
          <Image src={p.data.logo} alt={p.data.name}
                 width={100} height={100}
                 style="max-height:80px; width:auto; object-fit:contain; margin-bottom:0.75rem;" />
        )}
        <h3 style="margin-top:0; font-size:1rem;">{p.data.name}</h3>
        <p style="font-size:0.85rem;">{p.data.description}</p>
        {p.data.url && (
          <a href={p.data.url} target="_blank" style="font-size:0.82rem; color:#0066cc;">
            Spletna stran →
          </a>
        )}
      </div> 
    ))}
  </div>

  
  <SectionNews tag="professional" label="Novice iz industrije" />
</Base>