---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const partners     = await getCollection("industryPartners");
const achievements = await getCollection("achievements");
const base = import.meta.env.BASE_URL;

const industryAchievements = achievements.filter(a => {
  const tags = Array.isArray(a.data.tags) ? a.data.tags : [a.data.tags];
  return tags.includes("professional");
});
---
<Base title="Industry">
  <h1>Industry</h1>

  <h2>Who We Collaborate With</h2>
  {partners.length === 0 && <p class="meta">No partners listed yet.</p>}
  <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1rem; margin-bottom:2rem;">
    {partners.map(p => (
      <div class="card" style="text-align:center;">
        {p.data.logo && (
  <img src={typeof p.data.logo === "string" ? p.data.logo : (p.data.logo as any).src}
       alt={p.data.name}
       style="max-height:60px; object-fit:contain; margin-bottom:0.75rem;" />
)}
        <h3 style="margin-top:0; font-size:1rem;">{p.data.name}</h3>
        <p style="font-size:0.85rem;">{p.data.description}</p>
        {p.data.url && <a href={p.data.url} target="_blank" style="font-size:0.82rem; color:#0066cc;">Website →</a>}
      </div>
    ))}
  </div>

  <h2>Achievements & Projects</h2>
  {industryAchievements.length === 0 && <p class="meta">No achievements listed yet.</p>}
  {industryAchievements.map(a => (
    <div class="card">
      <h3>{a.data.title}</h3>
      <p class="meta">{new Date(a.data.date).toLocaleDateString("en-GB")}</p>
      <p>{a.data.description}</p>
    </div>
  ))}

  <SectionNews tag="professional" label="Industry News" />
</Base>