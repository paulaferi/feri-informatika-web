---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const partners = await getCollection("industryPartners");

const sidebarLinks = partners.map(p => ({
  label: p.data.name,
  href: `${base}/industry#${p.id}`,
}));
---
<Base title="Industry" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Industry</h1>
  <div class="page-title-rule"></div>
  <p class="page-subtitle">Who we work with</p>

  {partners.length === 0 && (
    <div class="card"><p class="empty-state" style="margin:0;">No partners listed yet.</p></div>
  )}

  {partners.map(p => (
    <div class="partner-card" id={p.id}>
      {p.data.logo && (
        <div class="partner-logo">
          <Image src={p.data.logo} alt={p.data.name} width={92} height={50} />
        </div>
      )}
      <div class="partner-body">
        <p class="partner-name">{p.data.name}</p>
        <p class="partner-desc">{p.data.description}</p>
        {p.data.url && (
          <a href={p.data.url} target="_blank" class="partner-link">Website →</a>
        )}
      </div>
    </div>
  ))}

  <SectionNews tag="professional" label="Latest News" />

</Base>
