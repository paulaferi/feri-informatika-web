---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const groups = await getCollection("interestGroups");
const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Laboratories",    href: `${base}/laboratories` },
  { label: "Interest Groups", href: `${base}/interest-groups` },
  { label: "Staff",           href: `${base}/staff` },
];
---
<Base title="Interest Groups" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Interest Groups</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>Interest groups at the Institute of Informatics bring together students and researchers around shared topics, fostering collaboration and knowledge exchange beyond the scope of formal research projects.</p>
    </div>

    <div class="section-heading"><h3>Interest Groups of the Institute</h3></div>

    <ul class="arrow-list">
      {groups.map(g => (
        <li>
          <span class="arrow-icon">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <a href={`${base}/interest-groups/${g.id}`}>{g.data.name}</a>
        </li>
      ))}
      {groups.length === 0 && <li class="empty-state">No interest groups listed yet.</li>}
    </ul>
  </div>

  <SectionNews tag="interest-groups" label="Latest News" />

</Base>
