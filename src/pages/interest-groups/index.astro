---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const groups = await getCollection("interestGroups");
const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Laboratoriji",    href: `${base}/laboratories` },
  { label: "Interesne skupine", href: `${base}/interest-groups` },
  { label: "Osebje",           href: `${base}/staff` },
];
---
<Base title="Interesne skupine" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Zainteresirane skupine</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>Zainteresirane skupine na Inštitutu za informatiko združujejo študente in raziskovalce okoli skupnih tem ter spodbujajo sodelovanje in izmenjavo znanja tudi zunaj okvira uradnih raziskovalnih projektov.</p>
    </div>

    <div class="section-heading"><h3>Interesne skupine na Inštitutu za informatiko</h3></div>

    <ul class="arrow-list">
      {groups.map(g => (
        <li>
          <span class="arrow-icon">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <a href={`${base}/interest-groups/${g.id}`}>{g.data.name}</a>
        </li>
      ))}
      {groups.length === 0 && <li class="empty-state">Ni na voljo še nobene zainteresirane skupine.</li>}
    </ul>
  </div>

  <SectionNews tag="interest-groups" label="Najnovejše novice" />

</Base>
