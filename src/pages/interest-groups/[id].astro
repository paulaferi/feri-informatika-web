---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const groups = await getCollection("interestGroups");
  return groups.map(g => ({ params: { id: g.id }, props: { group: g } }));
}

const { group } = Astro.props;
const { Content } = await render(group);
const base = import.meta.env.BASE_URL;

const allGroups = await getCollection("interestGroups");

const sidebarLinks = [
  { label: "Laboratoriji", href: `${base}/laboratories` },
  {
    label: "Interesne skupine",
    href: `${base}/interest-groups`,
    children: allGroups.map(g => ({
      label: g.data.name,
      href: `${base}/interest-groups/${g.id}`,
    })),
  },
  { label: "Osebje", href: `${base}/staff` },
];
---
<Base title={group.data.name} sidebarLinks={sidebarLinks}>

  <h2 style="font-family:'Titillium Web',sans-serif; font-size:1.4rem; font-weight:400;
             color:#222; margin-bottom:1.25rem;">
    {group.data.name}
  </h2>

  <div class="card">

    <!-- Descripción -->
    <div style="display:flex; gap:0.75rem; align-items:stretch; margin-bottom:1.25rem;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px;"></div>
      <p style="margin:0; text-align:left;">{group.data.description}</p>
    </div>

    <!-- Contenido completo -->
    {group.data.body && (
      <div style="margin-bottom:1rem;">
        <div style="display:flex; gap:0.75rem; align-items:center; margin-bottom:0.6rem;">
          <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px; align-self:stretch;"></div>
          <h3 style="margin:0; font-family:'Titillium Web',sans-serif; font-size:1rem; font-weight:700; color:#222;">
            O skupini
          </h3>
        </div>
        <div class="prose"><Content /></div>
      </div>
    )}

    <!-- External link -->
    {group.data.url && (
      <div style="margin-top:1.25rem; padding-top:1rem; border-top:1px solid #eee;">
        <a href={group.data.url} target="_blank" style="color:#006A8E; font-size:0.9rem;">
          Spletna stran skupine →
        </a>
      </div>
    )}

  </div>

  <SectionNews tag="interest-groups" label="ZADNJE NOVICE" />
</Base>