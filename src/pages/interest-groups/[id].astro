---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const groups = await getCollection("interestGroups");
  return groups.map(g => ({ params: { id: g.id }, props: { group: g } }));
}

const { group } = Astro.props;
const { Content } = await render(group);
const base = import.meta.env.BASE_URL;

const allGroups = await getCollection("interestGroups");

const sidebarLinks = [
  { label: "Laboratories", href: `${base}/laboratories` },
  {
    label: "Interest Groups",
    href: `${base}/interest-groups`,
    children: allGroups.map(g => ({
      label: g.data.name,
      href: `${base}/interest-groups/${g.id}`,
    })),
  },
  { label: "Staff", href: `${base}/staff` },
];
---
<Base title={group.data.name} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{group.data.name}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="intro"><p>{group.data.description}</p></div>

    {group.data.body && (
      <div>
        <div class="section-heading"><h3>About the Group</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {group.data.url && (
      <div class="external-link">
        <a href={group.data.url} target="_blank">Group website →</a>
      </div>
    )}

  </div>

  <SectionNews tag="interest-groups" label="Najnovejše novice" />

</Base>
