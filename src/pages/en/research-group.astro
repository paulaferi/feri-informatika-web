---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const sidebarLinks = [
  { label: "Research Areas",  href: localePath(lang, "/research-group/areas") },
  { label: "Link to SICRIS", href: localePath(lang, "/research-group/sicris") },
];
---
<Base title={t("researchGroup.title")} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{t("researchGroup.title")}</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>The Institute of Informatics brings together an active research group working in the field of information systems development and management. Researchers collaborate on numerous national and international projects and publish results in leading scientific journals and conferences. The group covers a broad spectrum of areas, from artificial intelligence and data technologies to cybersecurity and software engineering.</p>
    </div>
  </div>

  <SectionNews tag="scientific" label={t("common.latestNews")} />

</Base>