---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { getCollection, render } from "astro:content";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

export async function getStaticPaths() {
  const groups = await getCollection("interestGroups");
  return groups.map(g => ({ params: { id: g.id }, props: { group: g } }));
}

const lang = "en";
const t = useTranslations(lang);
const { group } = Astro.props;
const { Content } = await render(group);

const allGroups = await getCollection("interestGroups");

const sidebarLinks = [
  { label: t("about.sidebar.labs"), href: localePath(lang, "/laboratories") },
  {
    label: t("about.sidebar.groups"),
    href: localePath(lang, "/interest-groups"),
    children: allGroups.map(g => ({
      label: g.data.name,
      href: localePath(lang, `/interest-groups/${g.id}`),
    })),
  },
  { label: t("about.sidebar.staff"), href: localePath(lang, "/staff") },
];
---
<Base title={group.data.name} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{group.data.name}</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro"><p>{group.data.description}</p></div>

    {group.data.body && (
      <div>
        <div class="section-heading"><h3>About the Group</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {group.data.url && (
      <div class="external-link">
        <a href={group.data.url} target="_blank">Group website →</a>
      </div>
    )}
  </div>

  <SectionNews tag="interest-groups" label={t("common.latestNews")} lang="en" />

</Base>