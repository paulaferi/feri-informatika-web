---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const opinions = (await getCollection("ethicsOpinions"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const sidebarLinks = [
  { label: t("research.sidebar.projects"),     href: localePath(lang, "/research/projects") },
  { label: t("research.sidebar.publications"), href: localePath(lang, "/research/publications") },
  { label: t("research.sidebar.ethics"),       href: localePath(lang, "/research/ethics") },
];
---
<Base title="Research Ethics Committee" lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Research Ethics Committee</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="section-heading"><h3>Information</h3></div>
    <ul class="arrow-list" style="margin-bottom:1.75rem;">
      <li>
        <span class="arrow-icon">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <a href={localePath(lang, "/research/ethics/mandate")}>Tasks and functioning of the Committee</a>
      </li>
      <li>
        <span class="arrow-icon">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <a href={localePath(lang, "/research/ethics/submissions")}>Submission of applications and decisions</a>
      </li>
    </ul>

    <div class="section-heading"><h3>Issued Opinions</h3></div>
    {opinions.length === 0 && <p class="empty-state" style="margin:0;">No opinions recorded yet.</p>}
    {opinions.length > 0 && (
      <div style="overflow-x:auto;">
        <table style="table-layout:fixed;">
          <colgroup>
            <col style="width:110px;" />
            <col style="width:34%;" />
            <col style="width:24%;" />
            <col style="width:auto;" />
          </colgroup>
          <thead>
            <tr>
              <th>Date</th><th>Research</th><th>Researchers</th><th>Decision</th>
            </tr>
          </thead>
          <tbody>
            {opinions.map(o => (
              <tr>
                <td style="white-space:nowrap; color:var(--muted); font-size:0.84rem;">
                  {new Date(o.data.date).toLocaleDateString("en-GB")}
                </td>
                <td style="word-wrap:break-word;">{o.data.research}</td>
                <td style="word-wrap:break-word;">{o.data.researchers}</td>
                <td style="word-wrap:break-word;">{o.data.decision ?? "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <SectionNews tag="scientific" label={t("common.latestNews")} lang="en" />

</Base>