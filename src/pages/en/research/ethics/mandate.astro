---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const sidebarLinks = [
  { label: t("research.sidebar.projects"),     href: localePath(lang, "/research/projects") },
  { label: t("research.sidebar.publications"), href: localePath(lang, "/research/publications") },
  {
    label: t("research.sidebar.ethics"),
    href: localePath(lang, "/research/ethics"),
    children: [
      { label: "Tasks and functioning of the Committee", href: localePath(lang, "/research/ethics/mandate") },
      { label: "Submission of applications and decisions", href: localePath(lang, "/research/ethics/submissions") },
    ],
  },
];
---
<Base title="Tasks and functioning of the Committee" lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Tasks and Functioning of the Committee</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="section-heading"><h3>About the Committee</h3></div>
    <p>The Research Ethics Committee of the Institute of Informatics oversees ethical conduct across all research activities carried out within the institute.</p>

    <div class="section-heading"><h3>Committee Mandate</h3></div>
    <p style="margin-bottom:0;">The Committee reviews research proposals, issues opinions, and monitors compliance with ethical standards throughout the entire research lifecycle.</p>
  </div>

  <SectionNews tag="scientific" label={t("common.latestNews")} lang="en" />

</Base>