---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const all    = await getCollection("projects");
const active = all.filter(p => p.data.status === "active");
const past   = all.filter(p => p.data.status === "past");

const sidebarLinks = [
  { label: t("research.sidebar.projects"),     href: localePath(lang, "/research/projects") },
  { label: t("research.sidebar.publications"), href: localePath(lang, "/research/publications") },
  { label: t("research.sidebar.ethics"),       href: localePath(lang, "/research/ethics") },
];
---
<Base title={t("research.title")} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{t("research.sidebar.projects")}</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    {active.length > 0 && (
      <div>
        <div class="section-heading"><h3>{t("research.activeProjects")}</h3></div>
        <ul class="arrow-list" style="margin-bottom:1.5rem;">
          {active.map(p => (
            <li>
              <span class="arrow-icon">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <a href={localePath(lang, `/research/projects/${p.id}`)}>
                {p.data.title}
                {p.data.startYear && (
                  <span style="font-size:0.8rem; color:var(--muted); font-weight:400; margin-left:5px;">
                    ({p.data.startYear}–{p.data.endYear ?? t("research.present")})
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {past.length > 0 && (
      <div>
        <div class="section-heading"><h3>{t("research.pastProjects")}</h3></div>
        <ul class="arrow-list">
          {past.map(p => (
            <li>
              <span class="arrow-icon" style="background:var(--border);">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="#8a949e" stroke-width="1.9"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <a href={localePath(lang, `/research/projects/${p.id}`)}>
                {p.data.title}
                {p.data.startYear && (
                  <span style="font-size:0.8rem; color:var(--muted); font-weight:400; margin-left:5px;">
                    ({p.data.startYear}–{p.data.endYear ?? ""})
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {all.length === 0 && <p class="empty-state" style="margin:0;">{t("research.noProjects")}</p>}
  </div>

  <SectionNews tag="project" label={t("common.latestNews")} lang="en" />

</Base>