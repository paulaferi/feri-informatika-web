---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const sidebarLinks = [
  { label: t("research.sidebar.projects"),     href: localePath(lang, "/research/projects") },
  { label: t("research.sidebar.publications"), href: localePath(lang, "/research/publications") },
  { label: t("research.sidebar.ethics"),       href: localePath(lang, "/research/ethics") },
];
---
<Base title={t("research.sidebar.publications")} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{t("research.sidebar.publications")}</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>The research programme comprehensively addresses the management of complexity and quality assurance in the design, development, implementation and management of information systems (IS) and services. It focuses on developing new approaches, methods, technologies, concepts and algorithms in areas that enable and promote digital transformation.</p>
    </div>

    <div class="section-heading"><h3>External Resource</h3></div>
    <p style="margin-bottom:0;">
      <a href="https://cris.cobiss.net/ecris/si/sl/rest" target="_blank"
         style="font-weight:700; font-size:1rem;">{t("staff.cobiss")} →</a>
    </p>
  </div>

  <SectionNews tag="scientific" label={t("common.latestNews")} lang="en" />

</Base>