---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { getCollection, render } from "astro:content";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map(p => ({ params: { id: p.id }, props: { project: p } }));
}

const lang = "en";
const t = useTranslations(lang);
const { project } = Astro.props;
const { Content } = await render(project);

const allProjects = await getCollection("projects");

const sidebarLinks = [
  {
    label: t("research.sidebar.projects"),
    href: localePath(lang, "/research/projects"),
    children: allProjects.map(p => ({
      label: p.data.title,
      href: localePath(lang, `/research/projects/${p.id}`),
    })),
  },
  { label: t("research.sidebar.publications"), href: localePath(lang, "/research/publications") },
  { label: t("research.sidebar.ethics"),       href: localePath(lang, "/research/ethics") },
];
---
<Base title={project.data.title} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{project.data.title}</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro"><p>{project.data.description}</p></div>

    <div class="section-heading"><h3>Project Details</h3></div>
    <ul class="detail-list">
      <li><span><strong>Status:</strong> {project.data.status === "active" ? "Active" : "Completed"}</span></li>
      {project.data.startYear && (
        <li><span><strong>Period:</strong> {project.data.startYear}–{project.data.endYear ?? t("research.present")}</span></li>
      )}
      {project.data.funder && (
        <li><span><strong>Funding body:</strong> {project.data.funder}</span></li>
      )}
      {project.data.principalInvestigator && (
        <li><span><strong>Principal investigator:</strong> {project.data.principalInvestigator}</span></li>
      )}
    </ul>

    {project.data.body && (
      <div>
        <div class="section-heading"><h3>Description</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {project.data.newsLink && (
      <div class="external-link">
        <a href={project.data.newsLink}>Related news →</a>
      </div>
    )}
  </div>

  <a href={localePath(lang, "/research/projects")} class="back-link">← Back to Research Projects</a>

  <SectionNews tag="project" label={t("common.latestNews")} lang="en" />

</Base>