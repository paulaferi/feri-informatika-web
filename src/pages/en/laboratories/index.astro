---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const labs = await getCollection("laboratories");

const sidebarLinks = [
  { label: t("about.sidebar.labs"),   href: localePath(lang, "/laboratories") },
  { label: t("about.sidebar.groups"), href: localePath(lang, "/interest-groups") },
  { label: t("about.sidebar.staff"),  href: localePath(lang, "/staff") },
];
---
<Base title={t("about.sidebar.labs")} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{t("about.sidebar.labs")}</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>The Institute of Informatics conducts research in the field of information systems, solutions and services based on the use of information and communication technologies.</p>
    </div>

    <div class="section-heading"><h3>Laboratories of the Institute</h3></div>

    <ul class="arrow-list">
      {labs.map(lab => (
        <li>
          <span class="arrow-icon">
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <a href={localePath(lang, `/laboratories/${lab.id}`)}>
            {lab.data.name}
            {lab.data.acronym && (
              <span style="font-size:0.82rem; color:var(--muted); font-weight:400; margin-left:5px;">
                ({lab.data.acronym})
              </span>
            )}
          </a>
        </li>
      ))}
      {labs.length === 0 && <li class="empty-state">{t("common.noContent")}</li>}
    </ul>
  </div>

  <SectionNews tag="interest-groups" label={t("common.latestNews")} lang="en" />

</Base>