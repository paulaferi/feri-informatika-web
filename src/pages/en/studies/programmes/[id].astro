---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { getCollection, render } from "astro:content";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

export async function getStaticPaths() {
  const programmes = await getCollection("studyProgrammes");
  return programmes.map(p => ({ params: { id: p.id }, props: { programme: p } }));
}

const lang = "en";
const t = useTranslations(lang);
const { programme } = Astro.props;
const { Content } = await render(programme);

const allProgrammes = await getCollection("studyProgrammes");

const sidebarLinks = [
  {
    label: "Study Programmes",
    href: localePath(lang, "/studies/programmes"),
    children: allProgrammes.map(p => ({
      label: p.data.title,
      href: localePath(lang, `/studies/programmes/${p.id}`),
    })),
  },
  { label: "Student Activities", href: localePath(lang, "/studies/student-projects") },
];
---
<Base title={programme.data.title} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{programme.data.title}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    {programme.data.scope && (
      <div class="intro"><p>{programme.data.scope}</p></div>
    )}

    <div class="section-heading"><h3>Programme Information</h3></div>
    <ul class="detail-list">
      <li><span><strong>Type:</strong> {programme.data.type}</span></li>
      <li><span><strong>Duration:</strong> {programme.data.duration} {programme.data.duration === 1 ? "year" : "years"}</span></li>
      <li><span><strong>ECTS credits:</strong> {programme.data.ects}</span></li>
    </ul>

    {programme.data.body && (
      <div>
        <div class="section-heading"><h3>Curriculum &amp; General Information</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {programme.data.externalUrl && (
      <div class="external-link">
        <a href={programme.data.externalUrl} target="_blank">View programme on moja.um.si →</a>
      </div>
    )}

  </div>

  <a href={localePath(lang, "/studies/programmes")} class="back-link">← Back to Study Programmes</a>

  <SectionNews tag="student" label={t("common.latestNews")} lang="en" />

</Base>