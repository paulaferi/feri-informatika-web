---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const partners = await getCollection("industryPartners");

const sidebarLinks = partners.map(p => ({
  label: p.data.name,
  href: localePath(lang, `/industry#${p.id}`),
}));
---
<Base title={t("industry.title")} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{t("industry.title")}</h1>
  <div class="page-title-rule"></div>
  <p class="page-subtitle">Who we work with</p>

  {partners.length === 0 && (
    <div class="card"><p class="empty-state" style="margin:0;">{t("industry.noContent")}</p></div>
  )}

  {partners.map(p => (
    <div class="partner-card" id={p.id}>
      {p.data.logo && (
        <div class="partner-logo">
          <Image src={p.data.logo} alt={p.data.name} width={92} height={50} />
        </div>
      )}
      <div class="partner-body">
        <p class="partner-name">{p.data.name}</p>
        <p class="partner-desc">{p.data.description}</p>
        {p.data.url && (
          <a href={p.data.url} target="_blank" class="partner-link">Website →</a>
        )}
      </div>
    </div>
  ))}

  <SectionNews tag="professional" label={t("common.latestNews")} lang="en" />

</Base>