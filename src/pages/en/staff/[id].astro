---
import Base from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import SectionNews from "@/components/SectionNews.astro";
import { getCollection } from "astro:content";
import { marked } from "marked";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

export async function getStaticPaths() {
  const staff = await getCollection("staff");
  return staff.map(p => ({ params: { id: p.id }, props: { person: p } }));
}

const lang = "en";
const t = useTranslations(lang);
const { person } = Astro.props;

const allStaff = await getCollection("staff");
const sidebarLinks = [
  { label: t("about.sidebar.labs"),   href: localePath(lang, "/laboratories") },
  { label: t("about.sidebar.groups"), href: localePath(lang, "/interest-groups") },
  {
    label: t("about.sidebar.staff"),
    href: localePath(lang, "/staff"),
    children: allStaff.map(p => ({
      label: p.data.name,
      href: localePath(lang, `/staff/${p.id}`),
    })),
  },
];

const skipFields = new Set([
  'name', 'photo', 'title', 'role', 'email', 'phone',
  'office', 'contactHours', 'linkedin', 'cobiss', 'section',
]);

const knownLabels: Record<string, string> = {
  researchTopics:    "Main Research Areas",
  publications:      "Selected Publications",
  cv:                "Curriculum Vitae",
  teaching:          "Teaching",
  projects:          "Projects",
  editorial:         "Editorial Activities",
  awards:            "Awards",
  conferenceOrg:     "Conference Organisation",
  projectsCollab:    "International Projects and Collaboration",
  reviewerFor:       "Reviewer for Journals",
  certificates:      "Certificates",
  zaposlitev:        "Employment",
  kratkaBiografija:  "Short Biography",
  raziskovalnoDelo:  "Research Work",
  delovneIzkusnje:   "Work Experience",
  izobrazevanjeVTujini: "Education Abroad",
  studijInRaziskovanjeVTujini: "Study and Research Abroad",
  studijskeIzmenjave: "Study Exchanges",
  izmenjave:         "Exchanges",
  vabljenaPredavanja: "Invited Lectures",
  delavniceInVabljenaPredavanja: "Workshops and Invited Lectures",
  izvedbaDelavnic:   "Workshop Delivery",
  posebnaVabila:     "Special Invitations",
  organiziranjeInVodenjeKonferenc: "Conference Organisation and Chairing",
  sodelovanjePriKonferencah: "Conference Participation",
  konferencneAktivnosti: "Conference Activities",
  projektneAktivnosti: "Project Activities",
  vodjaKoordinatorProjekta: "Project Leader/Coordinator",
  sodelovanjePriProjektu: "Project Collaboration",
  recenzijskeInUredniskeAktivnosti: "Review and Editorial Activities",
  pedagoskaDejavnost: "Teaching Activities",
  mentorstva:        "Supervision",
  clanstvo:          "Membership",
  clanicaOdborov:    "Committee Membership",
  polozaji:          "Positions",
  sodelovanjeVDelovihSkupinah: "Working Group Participation",
  mednarodnaDejavnost: "International Activities",
  vMedijih:          "In the Media",
  izobraževanje:     "Education",
};

function camelToLabel(key: string): string {
  if (knownLabels[key]) return knownLabels[key];
  return key
    .replace(/([A-Z])/g, ' $1')
    .replace(/^./, s => s.toUpperCase())
    .trim();
}

const sections = Object.entries(person.data)
  .filter(([key, value]) => !skipFields.has(key) && value && typeof value === 'string' && value.trim() !== '')
  .map(([key, value]) => ({ key, label: camelToLabel(key), value: value as string }));
---
<Base title={person.data.name} lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{person.data.name}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div style="display:flex; gap:1.6rem; align-items:flex-start; flex-wrap:wrap; margin-bottom:1.5rem;">
      {person.data.photo
        ? <Image src={person.data.photo} alt={person.data.name} 
                 style="width:130px; height:130px; object-fit:cover; border-radius:4px;
                        border:1px solid var(--border); flex-shrink:0;" />
        : <div style="width:130px; height:130px; border-radius:4px; background:var(--um-blue-light);
                      display:flex; align-items:center; justify-content:center;
                      font-size:2.6rem; color:var(--um-blue); font-weight:700; flex-shrink:0;">
            {person.data.name.charAt(0)}
          </div>
      }
      <div style="flex:1; min-width:220px;">
        {person.data.title && (
          <p style="font-size:0.92rem; color:var(--muted); font-style:italic; margin-bottom:0.2rem;">
            {person.data.title}
          </p>
        )}
        <p style="color:var(--text); margin-bottom:0.85rem;">{person.data.role}</p>
        <ul class="contact-info" style="font-size:0.92rem;">
          {person.data.email && <li><strong>{t("staff.email")}:</strong> <a href={`mailto:${person.data.email}`}>{person.data.email}</a></li>}
          {person.data.phone && <li><strong>{t("staff.phone")}:</strong> {person.data.phone}</li>}
          {person.data.office && <li><strong>{t("staff.office")}:</strong> {person.data.office}</li>}
          {person.data.contactHours && <li><strong>{t("staff.contactHours")}:</strong> <a href={person.data.contactHours} target="_blank">link</a></li>}
          {person.data.linkedin && <li><strong>{t("staff.linkedin")}:</strong> <a href={person.data.linkedin} target="_blank">link</a></li>}
        </ul>
      </div>
    </div>

    {sections.map(({ label, value }) => (
      <div style="margin-bottom:1.4rem;">
        <div class="section-heading"><h3>{label}</h3></div>
        <div class="prose" set:html={marked.parse(value)} />
      </div>
    ))}

    {person.data.cobiss && (
      <div class="external-link">
        <div class="section-heading" style="margin-top:0;"><h3>{t("staff.cobiss")}</h3></div>
        <p style="margin-bottom:0.5rem;">Full publication list available on COBISS.</p>
        <a href={person.data.cobiss} target="_blank">View on COBISS →</a>
      </div>
    )}

  </div>

  <a href={localePath(lang, "/staff")} class="back-link">{t("staff.backLink")}</a>

  <SectionNews tag="student" label={t("common.latestNews")} lang="en" />

</Base>