---
import Base from "@/layouts/Base.astro";
import SectionNews from "@/components/SectionNews.astro";
import { useTranslations } from "@/i18n/translations";
import { localePath } from "@/i18n/utils";

const lang = "en";
const t = useTranslations(lang);

const sidebarLinks = [
  { label: "Research Areas", href: localePath(lang, "/research-group/areas") },
  { label: "Link to SICRIS", href: localePath(lang, "/research-group/sicris") },
];

const areas = [
  "Information Systems",
  "Software Engineering",
  "Embedded Systems",
  "Intelligent Systems",
  "Information and Communication Technologies",
];
---
<Base title="Research Areas" lang={lang} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Research Areas</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>The Institute of Informatics covers a wide range of research areas, including distributed systems, artificial intelligence, computer networks, software development and human-computer interaction.</p>
    </div>
    <div class="section-heading"><h3>Main Areas</h3></div>
    <ul class="dot-list">
      {areas.map(area => <li>{area}</li>)}
    </ul>
  </div>

  <SectionNews tag="scientific" label={t("common.latestNews")} lang="en" />

</Base>