---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const base = import.meta.env.BASE_URL;

const allNews = (await getCollection("news"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const projectNews = allNews.filter(n => {
  const tags = Array.isArray(n.data.tags) ? n.data.tags : [n.data.tags];
  return tags.includes("project");
});

const statusLabel: Record<string, string> = {
  active: "Activo", completed: "Completado", paused: "Pausado"
};
---
<Base title="Projects">
  <h1>Raziskovalni projekti</h1>
  {projects.map(p => (
    <div class="card">
      <h2><a href={`${base}/projects/${p.id}`}>{p.data.title}</a></h2>
      <p class="meta">{statusLabel[p.data.status]} · Desde {p.data.startYear}</p>
      <p>{p.data.description}</p>
    </div>
  ))}

  {projectNews.length > 0 && (
    <div style="margin-top:2.5rem;">
      <h2 style="font-size:1.1rem; margin-bottom:1rem; color:#555; border-top:1px solid #e0e0e0; padding-top:1.5rem;">
        Povezane novice
      </h2>
      <ul style="list-style:none; padding:0;">
        {projectNews.map(n => (
          <li style="margin-bottom:0.6rem; display:flex; align-items:baseline; gap:10px;">
            <span style="font-size:0.78rem; color:#aaa; white-space:nowrap;">
              {new Date(n.data.date).toLocaleDateString("es-ES")}
            </span>
            <a href={`${base}/news/${n.id}`}
               style="color:#1a5276; text-decoration:none; font-size:0.95rem;">
              {n.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</Base>