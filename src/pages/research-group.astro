---
import Base from "../layouts/Base.astro";
import SectionNews from "../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Raziskovalna področja", href: `${base}/research-group/areas` },
  { label: "Povezava do SICRIS",    href: `${base}/research-group/sicris` },
];
---
<Base title="Raziskovalna skupina" sidebarLinks={sidebarLinks}>

  <h2 style="font-family:'Titillium Web',sans-serif; font-size:1.4rem; font-weight:400;
             color:#222; margin-bottom:1.25rem;">
    Raziskovalna skupina
  </h2>

  <div class="card">
    <div style="display:flex; gap:0.75rem; align-items:stretch; margin-bottom:0;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px;"></div>
      <p style="margin:0; text-align:left;">
        Inštitut za informatiko združuje aktivno raziskovalno skupino, ki deluje na področju
        razvoja in upravljanja informacijskih sistemov. Raziskovalci inštituta sodelujejo v
        številnih nacionalnih in mednarodnih projektih ter objavljajo rezultate v uglednih
        znanstvenih revijah in na konferencah. Skupina pokriva širok spekter področij, od
        umetne inteligence in podatkovnih tehnologij do kibernetske varnosti in razvoja
        programske opreme.
      </p>
    </div>
  </div>

  <SectionNews tag="scientific" label="ZADNJE NOVICE" />

</Base>