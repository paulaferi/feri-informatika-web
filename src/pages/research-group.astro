---
import Base from "../layouts/Base.astro";
import SectionNews from "../components/SectionNews.astro";
---
<Base title="Research Group">
  <h1>Raziskovalna skupina</h1>

  <div class="card">
    <h2>Raziskovalna področja</h2>
    <p>
      Inštitut za informatiko pokriva široko paleto raziskovalnih področij, med katerimi so
      razpršeni sistemi, umetna inteligenca, računalniška omrežja, razvoj programske opreme
      in interakcija med človekom in računalnikom.
    </p>
  </div>

  <div class="card" style="margin-top:1rem;">
    <h2>Profil SICRIS</h2>
    <p>
      Polna informacija o raziskovalni skupini, vključno z člani in bibliografskimi zapisi,
      je na voljo v nacionalnem sistemu SICRIS.
    </p>
    <a href="https://www.sicris.si" target="_blank" style="color:#0066cc;">
      Oglej na SICRIS →
    </a>
  </div>

  <SectionNews tag="scientific" label="Znanstvene novice" />
</Base>