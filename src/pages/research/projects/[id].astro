---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map(p => ({ params: { id: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;

const allProjects = await getCollection("projects");

const sidebarLinks = [
  {
    label: "Research Projects",
    href: `${base}/research/projects`,
    children: allProjects.map(p => ({
      label: p.data.title,
      href: `${base}/research/projects/${p.id}`,
    })),
  },
  { label: "Publications",     href: `${base}/research/publications` },
  { label: "Ethics Committee", href: `${base}/research/ethics` },
];
---
<Base title={project.data.title} sidebarLinks={sidebarLinks}>

  <h1 class="page-title">{project.data.title}</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="intro"><p>{project.data.description}</p></div>

    <div class="section-heading"><h3>Project Details</h3></div>
    <ul class="detail-list">
      <li><span><strong>Status:</strong> {project.data.status === "active" ? "Active" : "Completed"}</span></li>
      {project.data.startYear && (
        <li><span><strong>Period:</strong> {project.data.startYear}–{project.data.endYear ?? "present"}</span></li>
      )}
      {project.data.funder && (
        <li><span><strong>Funding body:</strong> {project.data.funder}</span></li>
      )}
      {project.data.principalInvestigator && (
        <li><span><strong>Principal investigator:</strong> {project.data.principalInvestigator}</span></li>
      )}
    </ul>

    {project.data.body && (
      <div>
        <div class="section-heading"><h3>Description</h3></div>
        <div class="prose"><Content /></div>
      </div>
    )}

    {project.data.newsLink && (
      <div class="external-link">
        <a href={project.data.newsLink}>Related news →</a>
      </div>
    )}

  </div>

  <a href={`${base}/research/projects`} class="back-link">← Back to Research Projects</a>

  <SectionNews tag="project" label="Latest News" />

</Base>
