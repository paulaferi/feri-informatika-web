---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Raziskovalni projekti", href: `${base}/research/projects` },
  { label: "Publikacije",           href: `${base}/research/publications` },
  {
    label: "Etična komisija",
    href: `${base}/research/ethics`,
    children: [
      { label: "Naloge in delovanje komisije", href: `${base}/research/ethics/mandate` },
      { label: "Vlaganje vlog in odločitve",   href: `${base}/research/ethics/submissions` },
    ],
  },
];
---
<Base title="Vlaganje vlog in odločitve komisije" sidebarLinks={sidebarLinks}>

  <h2 style="font-family:'Titillium Web',sans-serif; font-size:1.4rem; font-weight:400;
             color:#222; margin-bottom:1.25rem;">
    Vlaganje vlog in odločitve komisije
  </h2>

  <div class="card">

    <div style="display:flex; gap:0.75rem; align-items:stretch; margin-bottom:1.25rem;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px;"></div>
      <p style="margin:0; text-align:left;">
        Raziskovalci, ki želijo vložiti vlogo za etično presojo, morajo izpolniti standardni
        obrazec in ga predložiti sekretariatu komisije.
      </p>
    </div>

    <div style="display:flex; gap:0.75rem; align-items:stretch; margin:0;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px;"></div>
      <p style="margin:0; text-align:left;">
        Odločitve se objavljajo v tabeli mnenj na
        <a href={`${base}/research/ethics`} style="color:#006A8E;">
          glavni strani Etične komisije
        </a>.
      </p>
    </div>

  </div>

  <SectionNews tag="scientific" label="ZADNJE NOVICE" />
</Base>