---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Raziskovalni projekti",  href: `${base}/research/projects` },
  { label: "Publikacije",       href: `${base}/research/publications` },
  {
    label: "Etični odbor",
    href: `${base}/research/ethics`,
    children: [
      { label: "Naloge in delovanje odbora", href: `${base}/research/ethics/mandate` },
      { label: "Predloži zahteve in odločitve odbora", href: `${base}/research/ethics/submissions` },
    ],
  },
];
---
<Base title="Predloži zahteve in odločitve odbora" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Vložitev vlog in odločitve</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="intro">
      <p>Raziskovalci, ki želijo predložiti zahtevek za etično pregled, morajo izpolniti standardno obliko in jo predložiti sekretariatu odbora.</p>
    </div>

    <div class="section-heading"><h3>Odločitve</h3></div>
    <p style="margin-bottom:0;">
      Odločitve so objavljene v tabeli mnenj na

      <a href={`${base}/research/ethics`}>glavna stran Etike komisije</a>.
    </p>

  </div>

  <SectionNews tag="scientific" label="Najnovejše novice" />

</Base>
