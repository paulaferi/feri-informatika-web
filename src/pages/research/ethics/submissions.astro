---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Research Projects",  href: `${base}/research/projects` },
  { label: "Publications",       href: `${base}/research/publications` },
  {
    label: "Ethics Committee",
    href: `${base}/research/ethics`,
    children: [
      { label: "Tasks and functioning of the Committee", href: `${base}/research/ethics/mandate` },
      { label: "Submission of applications and decisions", href: `${base}/research/ethics/submissions` },
    ],
  },
];
---
<Base title="Submission of applications and decisions" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Submission of Applications and Decisions</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="intro">
      <p>Researchers wishing to submit an application for ethical review must complete the standard form and submit it to the Committee secretariat.</p>
    </div>

    <div class="section-heading"><h3>Decisions</h3></div>
    <p style="margin-bottom:0;">
      Decisions are published in the opinions table on the
      <a href={`${base}/research/ethics`}>main Ethics Committee page</a>.
    </p>

  </div>

  <SectionNews tag="scientific" label="Latest News" />

</Base>
