---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Raziskovalni projekti",  href: `${base}/research/projects` },
  { label: "Publikacije",       href: `${base}/research/publications` },
  {
    label: "Etični odbor",
    href: `${base}/research/ethics`,
    children: [
      { label: "Naloge in delovanje odbora", href: `${base}/research/ethics/mandate` },
      { label: "Predloži zahteve in odločitve odbora", href: `${base}/research/ethics/submissions` },
    ],
  },
];
---
<Base title="Naloge in delovanje odbora" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Naloge in delovanje odbora</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="section-heading"><h3>O odboru</h3></div>
    <p>Etični odbor Instituta za informacije spremlja etično ravnanje v vseh raziskovalnih aktivnostih, ki se izvajajo znotraj instituta.</p>

    <div class="section-heading"><h3>Naloge odbora</h3></div>
    <p style="margin-bottom:0;">Odbor pregleduje predloge raziskav, izdaja mnenja in spremlja spoštovanje etičnih standardov skozi celoten raziskovalni cikel.</p>

  </div>

  <SectionNews tag="scientific" label="Najnovejše novice" />

</Base>
