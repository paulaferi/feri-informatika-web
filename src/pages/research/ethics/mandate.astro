---
import Base from "../../../layouts/Base.astro";
import SectionNews from "../../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Raziskovalni projekti", href: `${base}/research/projects` },
  { label: "Publikacije",           href: `${base}/research/publications` },
  {
    label: "Etična komisija",
    href: `${base}/research/ethics`,
    children: [
      { label: "Naloge in delovanje komisije", href: `${base}/research/ethics/mandate` },
      { label: "Vlaganje vlog in odločitve",   href: `${base}/research/ethics/submissions` },
    ],
  },
];
---
<Base title="Naloge in delovanje komisije" sidebarLinks={sidebarLinks}>

  <h2 style="font-family:'Titillium Web',sans-serif; font-size:1.4rem; font-weight:400;
             color:#222; margin-bottom:1.25rem;">
    Naloge in delovanje komisije
  </h2>

  <div class="card">

    <div style="display:flex; gap:0.75rem; align-items:center; margin-bottom:0.6rem;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px; min-height:24px;"></div>
      <h3 style="margin:0; font-family:'Titillium Web',sans-serif; font-size:1rem;
                 font-weight:700; color:#222;">O komisiji</h3>
    </div>
    <p style="margin-bottom:1.25rem;">
      Etična komisija za raziskave Inštituta za informatiko nadzoruje etično ravnanje
      pri vseh raziskovalnih dejavnostih, ki potekajo v okviru inštituta.
    </p>

    <div style="display:flex; gap:0.75rem; align-items:center; margin-bottom:0.6rem;">
      <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px; min-height:24px;"></div>
      <h3 style="margin:0; font-family:'Titillium Web',sans-serif; font-size:1rem;
                 font-weight:700; color:#222;">Pooblastila komisije</h3>
    </div>
    <p style="margin:0;">
      Komisija pregleduje raziskovalne predloge, izdaja mnenja in spremlja skladnost z
      etičnimi standardi skozi celoten življenjski cikel raziskave.
    </p>

  </div>

  <SectionNews tag="scientific" label="ZADNJE NOVICE" />
</Base>