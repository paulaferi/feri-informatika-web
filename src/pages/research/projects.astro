---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const all = await getCollection("projects");
const active = all.filter(p => p.data.status === "active");
const past   = all.filter(p => p.data.status === "past");

const sidebarLinks = [
  { label: "Raziskovalni projekti",  href: `${base}/research/projects` },
  { label: "Publikacije",       href: `${base}/research/publications` },
  { label: "Etični odbor",   href: `${base}/research/ethics` },
];
---
<Base title="Raziskovalni projekti" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Raziskovalni projekti</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    {active.length > 0 && (
      <div>
        <div class="section-heading"><h3>Aktivni projekti</h3></div>
        <ul class="arrow-list" style="margin-bottom:1.5rem;">
          {active.map(p => (
            <li>
              <span class="arrow-icon">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <a href={`${base}/research/projects/${p.id}`}>
                {p.data.title}
                {p.data.startYear && (
                  <span style="font-size:0.8rem; color:var(--muted); font-weight:400; margin-left:5px;">
                    ({p.data.startYear}–{p.data.endYear ?? "present"})
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {past.length > 0 && (
      <div>
        <div class="section-heading"><h3>Zaključeni projekti</h3></div>
        <ul class="arrow-list">
          {past.map(p => (
            <li>
              <span class="arrow-icon" style="background:var(--border);">
                <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="#8a949e" stroke-width="1.9"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <a href={`${base}/research/projects/${p.id}`}>
                {p.data.title}
                {p.data.startYear && (
                  <span style="font-size:0.8rem; color:var(--muted); font-weight:400; margin-left:5px;">
                    ({p.data.startYear}–{p.data.endYear ?? ""})
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {all.length === 0 && <p class="empty-state" style="margin:0;">Ni na voljo še nobenega projekta.</p>}
  </div>

  <SectionNews tag="project" label="Najnovejše novice" />

</Base>
