---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const all = await getCollection("projects");
const active = all.filter(p => p.data.status === "active");
const past   = all.filter(p => p.data.status === "past");

const sidebarLinks = [
  { label: "Raziskovalni projekti", href: `${base}/research/projects` },
  { label: "Publikacije",           href: `${base}/research/publications` },
  { label: "Etična komisija",       href: `${base}/research/ethics` },
];
---
<Base title="Raziskovalni projekti" sidebarLinks={sidebarLinks}>

  <h2 style="font-family:'Titillium Web',sans-serif; font-size:1.4rem; font-weight:400;
             color:#222; margin-bottom:1.25rem;">
    Raziskovalni projekti
  </h2>

  <div class="card">
    {active.length > 0 && (
      <>
        <div style="display:flex; gap:0.75rem; align-items:center; margin-bottom:0.75rem;">
          <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px; min-height:24px;"></div>
          <h3 style="margin:0; font-family:'Titillium Web',sans-serif; font-size:1rem;
                     font-weight:700; color:#222;">Aktivni projekti</h3>
        </div>
        <ul style="list-style:none; padding:0; margin:0 0 1.5rem;">
          {active.map(p => (
            <li style="display:flex; align-items:center; gap:0.75rem; padding:0.4rem 0;
                       border-bottom:1px solid #f5f5f5;">
              <span style="display:inline-flex; align-items:center; justify-content:center;
                           width:28px; height:28px; background:#ffc70f; flex-shrink:0;">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="#222" stroke-width="1.8"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <a href={`${base}/research/projects/${p.id}`}
                 style="color:#006A8E; text-decoration:none; font-size:1.05rem;">
                {p.data.title}
                {p.data.startYear && (
                  <span style="font-size:0.82rem; color:#888; margin-left:6px;">
                    ({p.data.startYear}–{p.data.endYear ?? "danes"})
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    {past.length > 0 && (
      <>
        <div style="display:flex; gap:0.75rem; align-items:center; margin-bottom:0.75rem;">
          <div style="width:4px; background:#ffc70f; flex-shrink:0; border-radius:1px; min-height:24px;"></div>
          <h3 style="margin:0; font-family:'Titillium Web',sans-serif; font-size:1rem;
                     font-weight:700; color:#222;">Zaključeni projekti</h3>
        </div>
        <ul style="list-style:none; padding:0; margin:0;">
          {past.map(p => (
            <li style="display:flex; align-items:center; gap:0.75rem; padding:0.4rem 0;
                       border-bottom:1px solid #f5f5f5;">
              <span style="display:inline-flex; align-items:center; justify-content:center;
                           width:28px; height:28px; background:#e0e0e0; flex-shrink:0;">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="#666" stroke-width="1.8"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <a href={`${base}/research/projects/${p.id}`}
                 style="color:#006A8E; text-decoration:none; font-size:1.05rem;">
                {p.data.title}
                {p.data.startYear && (
                  <span style="font-size:0.82rem; color:#888; margin-left:6px;">
                    ({p.data.startYear}–{p.data.endYear ?? ""})
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </>
    )}

    {all.length === 0 && (
      <p style="color:#888; margin:0;">Ni projektov.</p>
    )}
  </div>

  <SectionNews tag="project" label="ZADNJE NOVICE" />
</Base>