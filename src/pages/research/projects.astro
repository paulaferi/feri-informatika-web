---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const all = await getCollection("projects");
const active = all.filter(p => p.data.status === "active");
const past   = all.filter(p => p.data.status === "past");
---
<Base title="Research Projects">
  <h1>Research Projects</h1>

  <h2>Active Projects</h2>
  {active.length === 0 && <p class="meta">No active projects listed.</p>}
  {active.map(p => (
    <div class="card">
      <h3><a href={`${base}/research/projects/${p.id}`}>{p.data.title}</a></h3>
      <p class="meta">Since {p.data.startYear}{p.data.funder && ` · ${p.data.funder}`}</p>
      <p>{p.data.description}</p>
    </div>
  ))}

  <h2>Past Projects</h2>
  {past.length === 0 && <p class="meta">No past projects listed.</p>}
  {past.map(p => (
    <div class="card">
      <h3><a href={`${base}/research/projects/${p.id}`}>{p.data.title}</a></h3>
      <p class="meta">{p.data.startYear}–{p.data.endYear ?? "present"}{p.data.funder && ` · ${p.data.funder}`}</p>
      <p>{p.data.description}</p>
    </div>
  ))}

  <SectionNews tag="project" label="Project News" />
</Base>