---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";

const base = import.meta.env.BASE_URL;

const sidebarLinks = [
  { label: "Research Projects",  href: `${base}/research/projects` },
  { label: "Publications",       href: `${base}/research/publications` },
  { label: "Ethics Committee",   href: `${base}/research/ethics` },
];
---
<Base title="Publications" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Publications</h1>
  <div class="page-title-rule"></div>

  <div class="card">
    <div class="intro">
      <p>The full list of the Institute's publications is stored in the national COBISS/SICRIS system. In a future version, API integration is envisaged.</p>
    </div>

    <div class="section-heading"><h3>External Resource</h3></div>
    <p style="margin-bottom:0;">
      <a href="https://cris.cobiss.net/ecris/si/sl/rest" target="_blank"
         style="font-weight:700; font-size:1rem;">View publications on COBISS →</a>
    </p>
  </div>

  <SectionNews tag="scientific" label="Latest News" />

</Base>
