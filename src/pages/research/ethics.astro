---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const opinions = (await getCollection("ethicsOpinions"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const sidebarLinks = [
  { label: "Raziskovalni projekti",  href: `${base}/research/projects` },
  { label: "Publikacije",       href: `${base}/research/publications` },
  { label: "Etični odbor",   href: `${base}/research/ethics` },
];
---
<Base title="Etični odbor" sidebarLinks={sidebarLinks}>

  <h1 class="page-title">Odbor za raziskovalno etiko</h1>
  <div class="page-title-rule"></div>

  <div class="card">

    <div class="section-heading"><h3>Informacije</h3></div>
    <ul class="arrow-list" style="margin-bottom:1.75rem;">
      <li>
        <span class="arrow-icon">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <a href={`${base}/research/ethics/mandate`}>Naloge in delovanje odbora</a>
      </li>
      <li>
        <span class="arrow-icon">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="#1f2933" stroke-width="1.9"
                  stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <a href={`${base}/research/ethics/submissions`}>Predloži zahteve in odločitve odbora</a>
      </li>
    </ul>

    <div class="section-heading"><h3>Izdana mnenja</h3></div>
    {opinions.length === 0 && <p class="empty-state" style="margin:0;">Mnenja še niso bila zabeležena.</p>}
    {opinions.length > 0 && (
      <div style="overflow-x:auto;">
        <table style="table-layout:fixed;">
          <colgroup>
            <col style="width:110px;" />
            <col style="width:34%;" />
            <col style="width:24%;" />
            <col style="width:auto;" />
          </colgroup>
          <thead>
            <tr>
              <th>Datum</th>
              <th>Raziskava</th>
              <th>Raziskovalci</th>
              <th>Odločitev</th>
            </tr>
          </thead>
          <tbody>
            {opinions.map(o => (
              <tr>
                <td style="white-space:nowrap; color:var(--muted); font-size:0.84rem;">
                  {new Date(o.data.date).toLocaleDateString("en-GB")}
                </td>
                <td style="word-wrap:break-word;">{o.data.research}</td>
                <td style="word-wrap:break-word;">{o.data.researchers}</td>
                <td style="word-wrap:break-word;">{o.data.decision ?? "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

  </div>

  <SectionNews tag="scientific" label="Najnovejše novice" />

</Base>
