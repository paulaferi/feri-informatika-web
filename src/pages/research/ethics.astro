---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const opinions = (await getCollection("ethicsOpinions"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base title="Research Ethics Committee">
  <h1>Research Ethics Committee</h1>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin:1.5rem 0;">
    <a href={`${base}/research/ethics/mandate`} style="text-decoration:none;">
      <div class="card">
        <h3 style="margin-top:0; color:#0066cc;">Committee Mandate & Operations</h3>
        <p>About the commission and its powers.</p>
      </div>
    </a>
    <a href={`${base}/research/ethics/submissions`} style="text-decoration:none;">
      <div class="card">
        <h3 style="margin-top:0; color:#0066cc;">Submission of Applications</h3>
        <p>How to submit and committee decisions.</p>
      </div>
    </a>
  </div>

  <h2>List of Opinions Issued</h2>
  {opinions.length === 0 && <p class="meta">No opinions recorded yet.</p>}
  {opinions.length > 0 && (
    <div style="overflow-x:auto;">
      <table style="width:100%; border-collapse:collapse; table-layout:fixed;">
        <colgroup>
          <col style="width:110px;" />
          <col style="width:35%;" />
          <col style="width:25%;" />
          <col style="width:auto;" />
        </colgroup>
        <thead>
          <tr>
            <th style="text-align:left; padding:10px 12px; background:#f0f4ff; border-bottom:2px solid #ddd; font-size:0.82rem; text-transform:uppercase; letter-spacing:0.04em; color:#555;">Date</th>
            <th style="text-align:left; padding:10px 12px; background:#f0f4ff; border-bottom:2px solid #ddd; font-size:0.82rem; text-transform:uppercase; letter-spacing:0.04em; color:#555;">Research</th>
            <th style="text-align:left; padding:10px 12px; background:#f0f4ff; border-bottom:2px solid #ddd; font-size:0.82rem; text-transform:uppercase; letter-spacing:0.04em; color:#555;">Researchers</th>
            <th style="text-align:left; padding:10px 12px; background:#f0f4ff; border-bottom:2px solid #ddd; font-size:0.82rem; text-transform:uppercase; letter-spacing:0.04em; color:#555;">Decision</th>
          </tr>
        </thead>
        <tbody>
          {opinions.map((o, i) => (
            <tr style={i % 2 === 1 ? "background:#fafafa;" : ""}>
              <td style="padding:10px 12px; border-bottom:1px solid #eee; vertical-align:top; white-space:nowrap; font-size:0.88rem; color:#666;">
                {new Date(o.data.date).toLocaleDateString("en-GB")}
              </td>
              <td style="padding:10px 12px; border-bottom:1px solid #eee; vertical-align:top; font-size:0.9rem; word-wrap:break-word; overflow-wrap:break-word;">
                {o.data.research}
              </td>
              <td style="padding:10px 12px; border-bottom:1px solid #eee; vertical-align:top; font-size:0.9rem; word-wrap:break-word; overflow-wrap:break-word;">
                {o.data.researchers}
              </td>
              <td style="padding:10px 12px; border-bottom:1px solid #eee; vertical-align:top; font-size:0.9rem; word-wrap:break-word; overflow-wrap:break-word;">
                {o.data.decision ?? "—"}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</Base>