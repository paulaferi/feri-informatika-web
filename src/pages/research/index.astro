---
import Base from "../../layouts/Base.astro";
import SectionNews from "../../components/SectionNews.astro";
const base = import.meta.env.BASE_URL;
---
<Base title="Research">
  <h1>Raziskave</h1>
  <p>Pregled raziskovalnih dejavnosti inštituta, projektov, publikacij in etične komisije.</p>

  <div style="display:grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap:1rem; margin-top:1.5rem;">
    {[
      { label: "Raziskovalni projekti", href: `${base}/research/projects`, desc: "Aktivni in pretekli projekti" },
      { label: "Publikacije",      href: `${base}/research/publications`, desc: "Znanstvene članki prek SICRIS" },
      { label: "Etična komisija",  href: `${base}/research/ethics`, desc: "Naloge, delovanje in odločitve" },
    ].map(item => (
      <a href={item.href} style="text-decoration:none;">
        <div class="card" style="height:100%;">
          <h3 style="margin-top:0; color:#0066cc;">{item.label}</h3>
          <p style="margin:0;">{item.desc}</p>
        </div>
      </a>
    ))}
  </div>

  <SectionNews tag="scientific" label="Novice iz raziskav" />
</Base>