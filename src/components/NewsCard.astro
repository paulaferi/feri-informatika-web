---
import { Image } from "astro:assets";

interface Props {
  id: string;
  title: string;
  date: string;
  summary: string;
  coverImage?: ImageMetadata;
}

const { id, title, date, summary, coverImage } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<a href={`${base}/news/${id}`} class="grid-card">
  <div class="grid-card-image">
    {coverImage
      ? <Image src={coverImage} alt={title} 
               style="width:100%; height:100%; object-fit:cover;" />
      : <div class="grid-card-placeholder"><span>II · FERI</span></div>
    }
  </div>
  <div class="grid-card-accent"></div>
  <div class="grid-card-body">
    <time class="grid-card-date">
      {new Date(date).toLocaleDateString("en-GB", {
        day: "numeric", month: "long", year: "numeric"
      })}
    </time>
    <h3 class="grid-card-title">{title}</h3>
    <p class="grid-card-summary">{summary}</p>
  </div>
</a>
