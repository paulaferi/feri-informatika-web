---
import NewsCard from "./NewsCard.astro";
import { getCollection } from "astro:content";

interface Props {
  tag: string;
  label?: string;
}

const { tag, label = "Related News" } = Astro.props;

type NewsTag = "interest-groups" | "scientific" | "project" | "student" | "conference" | "professional" | "awards";

const allNews = await getCollection("news");
const filtered = allNews
  .filter(n => {
    const tags = Array.isArray(n.data.tags) ? n.data.tags : [n.data.tags];
    return tags.includes(tag as NewsTag);
  })
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

{filtered.length > 0 && (
  <div class="section-news">
    <h2>{label}</h2>
    <div class="news-grid">
      {filtered.map(n => (
        <NewsCard
          id={n.id}
          title={n.data.title}
          date={n.data.date.toString()}
          summary={n.data.summary}
          coverImage={n.data.coverImage}
        />
      ))}
    </div>
  </div>
)}

<style>
  .section-news {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e0e0e0;
  }
  .section-news h2 {
    font-size: 1.1rem;
    color: #555;
    margin-bottom: 1rem;
  }
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
</style>