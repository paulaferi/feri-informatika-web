---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  tag: string;
  label?: string;
}

const { tag, label = "Related News" } = Astro.props;
const base = import.meta.env.BASE_URL;

const allNews = await getCollection("news");
const filtered = allNews
  .filter((n: CollectionEntry<"news">) => {
    let tags: string[] = [];
    if (Array.isArray(n.data.tags)) {
      tags = n.data.tags.map((t: string) => String(t).trim());
    } else if (typeof n.data.tags === "string") {
      tags = [String(n.data.tags).trim()];
    }
    return tags.includes(tag);
  })
  .sort((a: CollectionEntry<"news">, b: CollectionEntry<"news">) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, 3);
---

{filtered.length > 0 && (
  <div class="section-news">
    <div class="section-news-title">{label}</div>
    <div class="card-grid">
      {filtered.map((n: CollectionEntry<"news">) => (
        <a href={`${base}/news/${n.id}`} class="grid-card">
          <div class="grid-card-image">
            {(() => {
              const cover = n.data.coverImage ?? (n.data.images && n.data.images[0]);
              return cover
                ? <Image src={cover} alt={n.data.title}  />
                : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
            })()}
          </div>
          <div class="grid-card-accent"></div>
          <div class="grid-card-body">
            <time class="grid-card-date">
              {new Date(n.data.date).toLocaleDateString("en-GB", {
                day: "numeric", month: "long", year: "numeric"
              })}
            </time>
            <h3 class="grid-card-title">{n.data.title}</h3>
            <p class="grid-card-summary">{n.data.summary}</p>
            <div class="grid-card-tags">
              {(Array.isArray(n.data.tags) ? n.data.tags : [String(n.data.tags)]).map((t: string) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
