---
import NewsCard from "./NewsCard.astro";
import { getCollection } from "astro:content";

interface Props {
  tag: string;
  label?: string;
}

const { tag, label = "Zadnje novice" } = Astro.props;

type NewsTag = "interest-groups" | "scientific" | "project" | "student" | "conference" | "professional" | "awards";

const allNews = await getCollection("news");
const filtered = allNews
  .filter(n => {
    let tags: string[] = [];
    if (Array.isArray(n.data.tags)) {
      tags = n.data.tags.map(t => String(t).trim());
    } else if (typeof n.data.tags === "string") {
      tags = [String(n.data.tags).trim()];
    }
    return tags.includes(tag);
  })
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

{filtered.length > 0 && (
  <div class="section-news">
    <h2>{label}</h2>
    <div class="news-grid">
      {filtered.map(n => (
        <NewsCard
          id={n.id}
          title={n.data.title}
          date={n.data.date.toString()}
          summary={n.data.summary}
          coverImage={n.data.coverImage}
        />
      ))}
    </div>
  </div>
)}