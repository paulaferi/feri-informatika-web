---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  tag: string;
  label?: string;
  lang?: "sl" | "en";
}

const { tag, label, lang = "sl" } = Astro.props;
const defaultLabel = lang === "en" ? "Latest News" : "Najnovejše novice";
const resolvedLabel = label ?? defaultLabel;
const tagLabels: Record<string, Record<string, string>> = {
  sl: {
    student: "Študentsko", conference: "Konferenca", scientific: "Znanstveno",
    professional: "Strokovno", project: "Projekt", awards: "Nagrade",
    "interest-groups": "Interesne skupine",
  },
  en: {
    student: "Student", conference: "Conference", scientific: "Scientific",
    professional: "Professional", project: "Project", awards: "Awards",
    "interest-groups": "Interest Groups",
  },
};

function translateTag(t: string) {
  return tagLabels[lang]?.[t] ?? t;
}
const base = import.meta.env.BASE_URL;
const newsBase = lang === "en" ? `${base}/en/news` : `${base}/news`;
const locale = lang === "en" ? "en-GB" : "sl-SI";

const allNews = await getCollection("news");
const filtered = allNews
  .filter((n: CollectionEntry<"news">) => {
    let tags: string[] = [];
    if (Array.isArray(n.data.tags)) {
      tags = n.data.tags.map((t: string) => String(t).trim());
    } else if (typeof n.data.tags === "string") {
      tags = [String(n.data.tags).trim()];
    }
    return tags.includes(tag);
  })
  .sort((a: CollectionEntry<"news">, b: CollectionEntry<"news">) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  )
  .slice(0, 3);
---

{filtered.length > 0 && (
  <div class="section-news">
    <div class="section-news-title">{resolvedLabel}</div>
    <div class="card-grid">
      {filtered.map((n: CollectionEntry<"news">) => (
        <a href={`${newsBase}/${n.id}`} class="grid-card">
          <div class="grid-card-image">
            {(() => {
              const cover = n.data.coverImage ?? (n.data.images && n.data.images[0]);
              return cover
                ? <Image src={cover} alt={n.data.title}  />
                : <div class="grid-card-placeholder"><span>II · FERI</span></div>;
            })()}
          </div>
          <div class="grid-card-accent"></div>
          <div class="grid-card-body">
            <time class="grid-card-date">
              {new Date(n.data.date).toLocaleDateString(locale, {
                day: "numeric", month: "long", year: "numeric"
              })}
            </time>
            <h3 class="grid-card-title">{n.data.title}</h3>
            <p class="grid-card-summary">{n.data.summary}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
