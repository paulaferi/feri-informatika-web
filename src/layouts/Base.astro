---
interface Props {
  title: string;
  sidebarLinks?: { label: string; href: string; children?: { label: string; href: string }[] }[];
}
const { title, sidebarLinks } = Astro.props;
const base = import.meta.env.BASE_URL;

const mainNav = [
  { label: "O inštitutu",           href: `${base}/` },
 { label: "Raziskovalna skupina", href: `${base}/research-group/areas` },
 { label: "Raziskave", href: `${base}/research/projects` },
  { label: "Študij IPT in ITK", href: `${base}/studies/programmes` },
  { label: "Konferenčne aktivnosti", href: `${base}/conferences` },
  { label: "Industrija",             href: `${base}/industry` },
  { label: "Dosežki in aktivnosti",  href: `${base}/achievements` },
  { label: "Novice",                 href: `${base}/news` },
];
---
<!doctype html>
<html lang="sl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href={`${base}/styles/global.css`} />
  <title>{title} — Inštitut za informatiko FERI</title>
</head>
<body>

  <header class="site-header">
    <div class="header-inner">
      <div class="logo-group">
        <a href={`${base}/`}>
          <img src={`${base}/logos/feri-logo.png`} alt="FERI — Univerza v Mariboru" />
        </a>
      </div>
      <nav class="main-nav">
        {mainNav.map(item => (
          <a href={item.href}
             class={Astro.url.pathname === item.href ? "active" : ""}>
            {item.label}
          </a>
        ))}
        <a href={`${base}/admin`} class="cms-link">CMS</a>
      </nav>
    </div>
  </header>

  <div class={`page-wrapper${sidebarLinks && sidebarLinks.length > 0 ? "" : " no-sidebar"}`}>

    {sidebarLinks && sidebarLinks.length > 0 && (
      <aside class="sidebar">
        {sidebarLinks.map(link => {
  const isCurrentPage = Astro.url.pathname === link.href;
  const isChildActive = link.children && link.children.some(c => Astro.url.pathname === c.href);
  const isOpen = isCurrentPage || isChildActive;

  return (
    <div>
      <a href={link.href} class={isOpen ? "active" : ""}>
        {link.label}
      </a>
      {isOpen && link.children && (
        <div class="sidebar-children">
          {link.children.map(child => (
            <a href={child.href}
               class={`sidebar-child${Astro.url.pathname === child.href ? " active-child" : ""}`}>
              {Astro.url.pathname === child.href && (
                <span style="display:inline-block; width:0; height:0;
                             border-top:5px solid transparent;
                             border-bottom:5px solid transparent;
                             border-left:7px solid #666;
                             margin-right:6px; flex-shrink:0;">
                </span>
              )}
              {child.label}
            </a>
          ))}
        </div>
      )}
    </div>
  );
})}
      </aside>
    )}

    <div class="content">
      <slot />
    </div>

  </div>

</body>
</html>