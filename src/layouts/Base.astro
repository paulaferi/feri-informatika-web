---
import { getLangFromUrl, useTranslations, type Lang } from "@/i18n/translations";
import { getAlternateUrl, getNavLinks, localePath } from "@/i18n/utils";

interface Props {
  title: string;
  lang?: Lang;
  sidebarLinks?: { label: string; href: string; children?: { label: string; href: string }[] }[];
  fullWidth?: boolean;
  wide?: boolean;
}

const { title, sidebarLinks, fullWidth, wide } = Astro.props;
const lang: Lang = Astro.props.lang ?? getLangFromUrl(Astro.url, import.meta.env.BASE_URL);
const t = useTranslations(lang);
const alternateUrl = getAlternateUrl(Astro.url, lang);
const mainNav = getNavLinks(lang);
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href={`${base}/styles/global.css`} />
  <title>{title} — Institute of Informatics FERI</title>
</head>
<body>

  <div class="top-strip"></div>

  <header class="site-header">
    <div class="header-inner">

      <a href={localePath(lang, "/")} class="logo-group">
        <img src={`${base}/logos/ii-logo.png`} alt="Inštitut za Informatiko"
            onerror="this.style.display='none'" />
        <img src={`${base}/logos/feri-logo.png`} alt="FERI — Univerza v Mariboru" />
      </a>

      <div class="header-right">

        <a href={localePath(lang, "/")} class="brand-link">
          <span class="brand-name">{lang === "sl" ? "Inštitut za Informatiko" : "Institute of Informatics"}</span>
        </a>

        <nav class="main-nav">
          {mainNav.map(item => {
            const currentPath = Astro.url.pathname;
            let isActive = false;
            if (item.href.endsWith("/about")) {
              isActive = currentPath === item.href || currentPath.startsWith(item.href);
            } else if (item.href === localePath(lang, "/")) {
              isActive = currentPath === item.href;
            } else {
              const section = item.href.split('/').filter(Boolean).at(-1);
              const currentSection = currentPath.split('/').filter(Boolean).at(-1);
              isActive = !!section && section === currentSection;
            }
            return (
              <a href={item.href} class={isActive ? "active" : ""}>
                {t(item.key as any)}
              </a>
            );
          })}

          <a href={alternateUrl} class="lang-switcher" id="lang-switcher-link" aria-label="Switch language">
            {lang === "sl" ? "EN" : "SL"}
          </a>

          <a href={`${base}/admin`} class="cms-link">CMS</a>
        </nav>

      </div>
    </div>
  </header>

  {fullWidth ? (
  <slot />
) : (
  <div class={`page-wrapper${sidebarLinks && sidebarLinks.length > 0 ? "" : " no-sidebar"}${wide ? " wide" : ""}`}>

    {sidebarLinks && sidebarLinks.length > 0 && (
      <aside class="sidebar">
        <div class="sidebar-header">{lang === "sl" ? "Oddelek" : "Section"}</div>
        {sidebarLinks.map(link => {
          const currentPath = decodeURIComponent(Astro.url.pathname);
          const isCurrentPage = currentPath === link.href;
          const isChildActive = link.children &&
            link.children.some(c => currentPath === decodeURIComponent(c.href));
          const isOpen = isCurrentPage || isChildActive;
          return (
            <div>
              <a href={link.href} class={isOpen ? "active" : ""}>{link.label}</a>
              {isOpen && link.children && (
                <div class="sidebar-children">
                  {link.children.map(child => (
                    <a href={child.href}
                       class={`sidebar-child${currentPath === decodeURIComponent(child.href) ? " active-child" : ""}`}>
                      {child.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </aside>
    )}

    <div class="content">
      <slot />
    </div>

  </div>
)}

</body>
</html>