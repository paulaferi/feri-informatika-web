---
interface Props {
  title: string;
  sidebarLinks?: { label: string; href: string; children?: { label: string; href: string }[] }[];
}
const { title, sidebarLinks } = Astro.props;
const base = import.meta.env.BASE_URL;

const mainNav = [
  { label: "About the Institute",   href: `${base}/` },
  { label: "Research Group",        href: `${base}/research-group/areas` },
  { label: "Research",              href: `${base}/research/projects` },
  { label: "Studies IPT & ITK",     href: `${base}/studies/programmes` },
  { label: "Conference Activities", href: `${base}/conferences` },
  { label: "Industry",              href: `${base}/industry` },
  { label: "Achievements",          href: `${base}/achievements` },
  { label: "News",                  href: `${base}/news` },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href={`${base}/styles/global.css`} />
  <title>{title} — Institute of Informatics FERI</title>
</head>
<body>

  <div class="top-strip"></div>

  <header class="site-header">
    <div class="header-inner">

      
      <a href={`${base}/`} class="logo-group">
        <img src={`${base}/logos/ii-logo.png`} alt="Inštitut za Informatiko"
            onerror="this.style.display='none'" />
        <img src={`${base}/logos/feri-logo.png`} alt="FERI — Univerza v Mariboru" />
      </a>

      
      <div class="header-right">

        <a href={`${base}/`} class="brand-link">
          <span class="brand-name">INŠTITUT ZA INFORMATIKO</span>
          <span class="brand-sub">FAKULTETA ZA ELEKTROTEHNIKO, RAČUNALNIŠTVO IN INFORMATIKO</span>
        </a>

        <nav class="main-nav">
          {mainNav.map(item => {
            const currentPath = Astro.url.pathname;
            let isActive = false;
            if (item.href === `${base}/`) {
              isActive = currentPath === item.href;
            } else {
              const section = item.href.split('/').filter(Boolean)[1];
              const currentSection = currentPath.split('/').filter(Boolean)[1];
              isActive = section === currentSection;
            }
            return (
              <a href={item.href} class={isActive ? "active" : ""}>
                {item.label}
              </a>
            );
          })}
          <a href={`${base}/admin`} class="cms-link">CMS</a>
        </nav>

      </div>
    </div>
  </header>

  <div class={`page-wrapper${sidebarLinks && sidebarLinks.length > 0 ? "" : " no-sidebar"}`}>

    {sidebarLinks && sidebarLinks.length > 0 && (
      <aside class="sidebar">
        <div class="sidebar-header">Section</div>
        {sidebarLinks.map(link => {
          const currentPath = decodeURIComponent(Astro.url.pathname);
          const isCurrentPage = currentPath === link.href;
          const isChildActive = link.children &&
            link.children.some(c => currentPath === decodeURIComponent(c.href));
          const isOpen = isCurrentPage || isChildActive;
          return (
            <div>
              <a href={link.href} class={isOpen ? "active" : ""}>{link.label}</a>
              {isOpen && link.children && (
                <div class="sidebar-children">
                  {link.children.map(child => (
                    <a href={child.href}
                       class={`sidebar-child${currentPath === decodeURIComponent(child.href) ? " active-child" : ""}`}>
                      {child.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </aside>
    )}

    <div class="content">
      <slot />
    </div>

  </div>

</body>
</html>
